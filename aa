Mongo Collection Schema (license_source):



{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "/HRG/SIDB/2024-07/LicenseSource.json",
  "title": "LicenseSource",
  "description": "Schema for managing license source information",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "hon": {
      "description": "Unique Number",
      "type": "string",
      "minLength": 1
    },
    "scope": {
      "description": "Defines the level of the license",
      "type": "string",
      "enum": ["GLOBAL", "NATIONAL", "STATE"]
    },
    "country": {
      "description": "Country where the license is applicable",
      "type": "string",
      "minLength": 1
    },
    "state": {
      "description": "State where the license is applicable (required when scope is STATE)",
      "type": ["string", "null"]
    },
    "licenseType": {
      "description": "Type of license",
      "type": "string",
      "minLength": 1
    },
    "webAddress": {
      "description": "List of official web addresses",
      "type": ["array", "null"],
      "items": {
        "type": "string"
      }
    },
    "phone": {
      "description": "List of phone numbers",
      "type": ["array", "null"],
      "items": {
        "type": "string"
      }
    },
    "email": {
      "description": "List of email addresses",
      "type": ["array", "null"],
      "items": {
        "type": "string"
      }
    },
    "fax": {
      "description": "List of fax numbers",
      "type": ["array", "null"],
      "items": {
        "type": "string"
      }
    },
    "governingAgency": {
      "description": "Regulatory or governing authority",
      "type": ["string", "null"]
    },
    "multiState": {
      "description": "Indicates if license applies to multiple states",
      "type": ["string", "null"]
    },
    "expiration": {
      "description": "License expiration details",
      "type": ["string", "null"]
    },
    "licenseStatus": {
      "description": "Current status of the license",
      "type": ["string", "null"]
    },
    "disciplinaryActions": {
      "description": "Any disciplinary actions associated with the license",
      "type": ["string", "null"]
    },
    "additionalInformation": {
      "description": "Additional notes or metadata",
      "type": ["string", "null"]
    },
    "createdDate": {
      "description": "Creation timestamp",
      "type": ["string", "null"],
      "format": "date-time"
    },
    "updatedDate": {
      "description": "Last updated timestamp",
      "type": ["string", "null"],
      "format": "date-time"
    },
    "active": {
      "description": "Indicates if the license source is active",
      "type": ["boolean", "null"]
    }
  },
  "required": [
    "hon",
    "scope",
    "licenseType",
    "country"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "scope": { "const": "STATE" }
        }
      },
      "then": {
        "required": ["state"],
        "properties": {
          "state": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  ]
}
Indexes
licenseSourceSchema.index({ hon: 1 }, { unique: true, name: "idx_hon_unique" });
licenseSourceSchema.index({ scope: 1 }, { name: "idx_scope" });
licenseSourceSchema.index({ country: 1 }, { name: "idx_country" });
licenseSourceSchema.index({ state: 1 }, { name: "idx_state" });
licenseSourceSchema.index({ licenseType: 1 }, { name: "idx_license_type" });
licenseSourceSchema.index({ governingAgency: 1 }, { name: "idx_governing_agency" });
licenseSourceSchema.index({ scope: 1, state: 1 }, { name: "idx_scope_state" });
licenseSourceSchema.index({ active: 1 }, { name: "idx_active" });

