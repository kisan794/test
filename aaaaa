PROCEDURE load_array(
    nestedObj IN JSON_OBJECT_T,
    sTemplate IN VARCHAR2,
    sTmplFinal OUT VARCHAR2,
	sArrayTagName IN VARCHAR2,
	sTagName IN VARCHAR2
) AS
    valuesArray JSON_ARRAY_T;
    oneValue NVARCHAR2(32767);
    sTmplOne NVARCHAR2(32767);
BEGIN
    IF nestedObj.has(sArrayTagName)
	THEN
        IF nestedObj.get_type(sArrayTagName) = 'ARRAY' THEN
            valuesArray := nestedObj.get_array(sArrayTagName);

            -- Iterate through the array
            FOR j IN 0 .. valuesArray.get_size - 1 LOOP
                oneValue := valuesArray.get_string(j);

                -- Replace placeholder in the template
                sTmplOne := sTemplate;
                sTmplOne := REPLACE(sTmplOne, sTagName, oneValue);

                -- Concatenate the result
                sTmplFinal := sTmplFinal || sTmplOne;
            END LOOP;
        END IF;
    END IF;
END;



