PROCEDURE create_unitIdentifier(pnOrgUnitID IN NUMBER, pjsonOrgUnit IN JSON_OBJECT_T)
IS
  TYPE t_string_array IS TABLE OF VARCHAR2(50);
  arrType t_string_array := t_string_array(
	'sic',
	'taxID'	
  );
    
  sValue NVARCHAR2(2000);
BEGIN 
  FOR i IN 1..arrType.COUNT
  LOOP
    sValue := pjsonOrgUnit.get_String(arrType(i));  
    IF NVL(sValue, ' ' ) != ' '
    THEN
		UPDATE CONTACTDB_ORG_UNIT_IDENTIFIER 
		 SET VALUE = sValue
		 WHERE ORG_UNIT_ID = pnOrgUnitID and TYPE = arrType(i);
		  
		IF SQL%ROWCOUNT = 0
		THEN
		  INSERT INTO CONTACTDB_ORG_UNIT_IDENTIFIER (ID,TYPE,VALUE,ORG_UNIT_ID)
		  VALUES (CONTACTDB_OU_IDENTIFIER_ID_SEQ.NEXTVAL,arrType(i),sValue, pnOrgUnitID);
		END IF;
	ELSE
		DELETE CONTACTDB_ORG_UNIT_IDENTIFIER 		 
		 WHERE ORG_UNIT_ID = pnOrgUnitID and TYPE = arrType(i);
    END IF;
  END LOOP;	
  
END create_unitIdentifier;

