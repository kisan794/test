package com.hireright.sourceintelligence.service.migration;

import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.extension.ExtendWith;
import org.mockito.Mock;
import org.mockito.junit.jupiter.MockitoExtension;

import java.util.Arrays;
import java.util.Collections;
import java.util.List;

import static org.junit.jupiter.api.Assertions.*;
import static org.mockito.Mockito.*;

/**
 * Unit tests for MigrationProcessorFactory.
 * Tests processor selection and discovery logic.
 */
@ExtendWith(MockitoExtension.class)
class MigrationProcessorFactoryTest {

    @Mock
    private MigrationProcessor parchmentProcessor;

    @Mock
    private MigrationProcessor clearinghouseProcessor;

    private MigrationProcessorFactory factory;

    @BeforeEach
    void setUp() {
        when(parchmentProcessor.getMigrationType()).thenReturn("parchment");
        when(parchmentProcessor.supports("parchment")).thenReturn(true);
        when(parchmentProcessor.supports(anyString())).thenCallRealMethod();

        when(clearinghouseProcessor.getMigrationType()).thenReturn("clearinghouse");
        when(clearinghouseProcessor.supports("clearinghouse")).thenReturn(true);
        when(clearinghouseProcessor.supports(anyString())).thenCallRealMethod();
    }

    @Test
    void testGetProcessor_Success() {
        // Arrange
        List<MigrationProcessor> processors = Arrays.asList(parchmentProcessor, clearinghouseProcessor);
        factory = new MigrationProcessorFactory(processors);

        // Act
        MigrationProcessor result = factory.getProcessor("parchment");

        // Assert
        assertNotNull(result);
        assertEquals(parchmentProcessor, result);
    }

    @Test
    void testGetProcessor_MultipleProcessors() {
        // Arrange
        List<MigrationProcessor> processors = Arrays.asList(parchmentProcessor, clearinghouseProcessor);
        factory = new MigrationProcessorFactory(processors);

        // Act
        MigrationProcessor parchment = factory.getProcessor("parchment");
        MigrationProcessor clearinghouse = factory.getProcessor("clearinghouse");

        // Assert
        assertEquals(parchmentProcessor, parchment);
        assertEquals(clearinghouseProcessor, clearinghouse);
    }

    @Test
    void testGetProcessor_UnsupportedType() {
        // Arrange
        List<MigrationProcessor> processors = Arrays.asList(parchmentProcessor);
        factory = new MigrationProcessorFactory(processors);

        // Act & Assert
        IllegalArgumentException exception = assertThrows(IllegalArgumentException.class, () -> {
            factory.getProcessor("unknown");
        });

        assertTrue(exception.getMessage().contains("Unsupported migration type"));
        assertTrue(exception.getMessage().contains("unknown"));
    }

    @Test
    void testGetProcessor_NullType() {
        // Arrange
        List<MigrationProcessor> processors = Arrays.asList(parchmentProcessor);
        factory = new MigrationProcessorFactory(processors);

        // Act & Assert
        IllegalArgumentException exception = assertThrows(IllegalArgumentException.class, () -> {
            factory.getProcessor(null);
        });

        assertTrue(exception.getMessage().contains("Migration type cannot be null or empty"));
    }

    @Test
    void testGetProcessor_EmptyType() {
        // Arrange
        List<MigrationProcessor> processors = Arrays.asList(parchmentProcessor);
        factory = new MigrationProcessorFactory(processors);

        // Act & Assert
        IllegalArgumentException exception = assertThrows(IllegalArgumentException.class, () -> {
            factory.getProcessor("");
        });

        assertTrue(exception.getMessage().contains("Migration type cannot be null or empty"));
    }

    @Test
    void testGetProcessor_WhitespaceType() {
        // Arrange
        List<MigrationProcessor> processors = Arrays.asList(parchmentProcessor);
        factory = new MigrationProcessorFactory(processors);

        // Act & Assert
        IllegalArgumentException exception = assertThrows(IllegalArgumentException.class, () -> {
            factory.getProcessor("   ");
        });

        assertTrue(exception.getMessage().contains("Migration type cannot be null or empty"));
    }

    @Test
    void testGetSupportedTypes_SingleProcessor() {
        // Arrange
        List<MigrationProcessor> processors = Collections.singletonList(parchmentProcessor);
        factory = new MigrationProcessorFactory(processors);

        // Act
        String supportedTypes = factory.getSupportedTypes();

        // Assert
        assertEquals("parchment", supportedTypes);
    }

    @Test
    void testGetSupportedTypes_MultipleProcessors() {
        // Arrange
        List<MigrationProcessor> processors = Arrays.asList(parchmentProcessor, clearinghouseProcessor);
        factory = new MigrationProcessorFactory(processors);

        // Act
        String supportedTypes = factory.getSupportedTypes();

        // Assert
        assertTrue(supportedTypes.contains("parchment"));
        assertTrue(supportedTypes.contains("clearinghouse"));
        assertTrue(supportedTypes.contains(", "));
    }

    @Test
    void testGetSupportedTypes_NoProcessors() {
        // Arrange
        List<MigrationProcessor> processors = Collections.emptyList();
        factory = new MigrationProcessorFactory(processors);

        // Act
        String supportedTypes = factory.getSupportedTypes();

        // Assert
        assertEquals("none", supportedTypes);
    }

    @Test
    void testIsSupported_True() {
        // Arrange
        List<MigrationProcessor> processors = Arrays.asList(parchmentProcessor, clearinghouseProcessor);
        factory = new MigrationProcessorFactory(processors);

        // Act
        boolean isParchmentSupported = factory.isSupported("parchment");
        boolean isClearinghouseSupported = factory.isSupported("clearinghouse");

        // Assert
        assertTrue(isParchmentSupported);
        assertTrue(isClearinghouseSupported);
    }

    @Test
    void testIsSupported_False() {
        // Arrange
        List<MigrationProcessor> processors = Arrays.asList(parchmentProcessor);
        factory = new MigrationProcessorFactory(processors);

        // Act
        boolean isSupported = factory.isSupported("unknown");

        // Assert
        assertFalse(isSupported);
    }

    @Test
    void testIsSupported_NullType() {
        // Arrange
        List<MigrationProcessor> processors = Arrays.asList(parchmentProcessor);
        factory = new MigrationProcessorFactory(processors);

        // Act
        boolean isSupported = factory.isSupported(null);

        // Assert
        assertFalse(isSupported);
    }

    @Test
    void testIsSupported_EmptyType() {
        // Arrange
        List<MigrationProcessor> processors = Arrays.asList(parchmentProcessor);
        factory = new MigrationProcessorFactory(processors);

        // Act
        boolean isSupported = factory.isSupported("");

        // Assert
        assertFalse(isSupported);
    }

    @Test
    void testGetProcessor_CaseInsensitive() {
        // Arrange
        List<MigrationProcessor> processors = Arrays.asList(parchmentProcessor);
        factory = new MigrationProcessorFactory(processors);
        
        // Mock case-insensitive support
        when(parchmentProcessor.supports("PARCHMENT")).thenReturn(true);
        when(parchmentProcessor.supports("Parchment")).thenReturn(true);

        // Act
        MigrationProcessor upperCase = factory.getProcessor("PARCHMENT");
        MigrationProcessor mixedCase = factory.getProcessor("Parchment");

        // Assert
        assertEquals(parchmentProcessor, upperCase);
        assertEquals(parchmentProcessor, mixedCase);
    }

    @Test
    void testGetProcessor_ErrorMessageIncludesAvailableTypes() {
        // Arrange
        List<MigrationProcessor> processors = Arrays.asList(parchmentProcessor, clearinghouseProcessor);
        factory = new MigrationProcessorFactory(processors);

        // Act & Assert
        IllegalArgumentException exception = assertThrows(IllegalArgumentException.class, () -> {
            factory.getProcessor("unknown");
        });

        String message = exception.getMessage();
        assertTrue(message.contains("parchment"));
        assertTrue(message.contains("clearinghouse"));
    }
}




