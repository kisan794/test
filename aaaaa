FUNCTION is_sidb2(pnOrderServiceID IN NUMBER)
RETURN NUMBER
IS
	nValue NUMBER := SIDB2_NONE;
BEGIN

	SELECT DECODE (sdk_order_service.get_property(  pnOrderServiceID, 'SIDB_VERSION' ), 'SIDB2_MANUAL', SIDB2_MANUAL, 'SIDB2_AUTO', SIDB2_AUTO, SIDB2_NONE )
	INTO nValue 
	FROM DUAL;
	
	RETURN nValue;
	
END is_sidb2; 

