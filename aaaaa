PROCEDURE create_emails(pnOrgUnitID IN NUMBER,  psReason IN VARCHAR2, psTag IN VARCHAR2, psType IN VARCHAR2, pjsonOrgUnit IN JSON_OBJECT_T)
IS
TMPL_EMAIL CONSTANT NVARCHAR2(32767) :=
    '<address>
      <address><![CDATA[%EMAIL_ADDRESS%]]></address>
      <comment><![CDATA[]]></comment>
      <recipient><![CDATA[]]></recipient>
      <department><![CDATA[]]></department>
    </address>';
  
TMPL_EMAILS CONSTANT NVARCHAR2(32767) :=
	'<?xml version="1.0" encoding="UTF-8"?>
	<data><version>1</version>' || TMPL_COMMON_INFO || '<addresses>%EMAIL_ADDRESSES%</addresses></data>';

  sTmplEmail              NVARCHAR2(32767);
  sTmplFinalEmail          NVARCHAR2(32767);
  sTmplFinalEmails         NVARCHAR2(32767);

  jsonContactObj JSON_OBJECT_T;
  arrEmails JSON_ARRAY_T;
  
  emailAddress VARCHAR2(100);
  sPriority VARCHAR2(20);
  
BEGIN 
  IF pjsonOrgUnit.has(psTag) 
  THEN  
    -- Extract the JSON array
    jsonContactObj := TREAT(pjsonOrgUnit.get(psTag) AS JSON_OBJECT_T);
     
    IF jsonContactObj IS NULL
    THEN   
		clear_contact(pnOrgUnitID, psReason, psType);			
		RETURN;
    END IF;   
        
    arrEmails := jsonContactObj.get_Array('emails');
	IF arrEmails IS NULL 
	THEN
		clear_contact(pnOrgUnitID, psReason, psType);		
		RETURN;
	END IF;
             
	FOR i IN 0 .. arrEmails.get_size - 1
	LOOP
	  sTmplEmail := TMPL_EMAIL;
	  emailAddress := arrEmails.get_string(i);
	  inject(sTmplEmail, '%EMAIL_ADDRESS%', emailAddress);
	  sTmplFinalEmail := sTmplFinalEmail || sTmplEmail;
	END LOOP;   
     
    -- Get template
    sTmplFinalEmails := TMPL_EMAILS;
      
    update_commonDetails(sTmplFinalEmails, jsonContactObj, sPriority);
    
    inject(sTmplFinalEmails, '%EMAIL_ADDRESSES%', sTmplFinalEmail);
    
	UPDATE CONTACTDB_ORG_UNIT_CONTACT 
	SET DATA = sTmplFinalEmails, PRIORITY = NVL(TO_NUMBER(sPriority), 0)
	WHERE REASON = psReason AND TYPE = psType AND ORG_UNIT_ID = pnOrgUnitID;	

	IF SQL%ROWCOUNT = 0
	THEN
		INSERT INTO CONTACTDB_ORG_UNIT_CONTACT (ID, NAME, REASON, TYPE, PRIORITY, ORG_UNIT_ID, DATA)
		   VALUES (CONTACTDB_OU_CONTACT_ID_SEQ.NEXTVAL, 'undefined', psReason, psType, NVL(TO_NUMBER(sPriority), 0), pnOrgUnitID, sTmplFinalEmails);
	END IF;
	
  ELSE
	clear_contact(pnOrgUnitID, psReason, psType);			
  END IF;
       
END create_emails;


