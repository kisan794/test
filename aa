INSERT INTO INFORMATION_REQUEST_TEMPLATE (
    ID,
    TITLE,
    TYPE,
    STATE,
    SEND_TO_APPLICANT,
    SEND_TO_RECRUITER,
    IS_HARDCOPY,
    CREATION_DATE,
    CREATED_BY
)
SELECT 
    INFORMATION_REQUEST_TEMPLATE_SEQ.NEXTVAL,
    TITLE || ' (SIDB)',
    TYPE,
    STATE,
    SEND_TO_APPLICANT,
    SEND_TO_RECRUITER,
    IS_HARDCOPY,
    SYSDATE,
    'ADMIN'  -- Change to your username
FROM INFORMATION_REQUEST_TEMPLATE
WHERE ID = 2245;

-- Get the new template ID
SELECT INFORMATION_REQUEST_TEMPLATE_SEQ.CURRVAL AS NEW_TEMPLATE_ID 
FROM DUAL;




INSERT INTO INFORMATION_REQUEST_DESCRIPTION (
    ID,
    TEMPLATE_ID,
    LANGUAGE,
    SHORT_APPLICANT_DESCRIPTION,
    APPLICANT_DESCRIPTION,
    SHORT_RECRUITER_DESCRIPTION,
    RECRUITER_DESCRIPTION
)
SELECT 
    INFORMATION_REQUEST_DESCRIPTION_SEQ.NEXTVAL,
    2300,  -- REPLACE with your new template ID
    LANGUAGE,
    REPLACE(NVL(SHORT_APPLICANT_DESCRIPTION, ''), '${employment:employerName}', '${employment:employerSIDB}'),
    REPLACE(NVL(APPLICANT_DESCRIPTION, ''), '${employment:employerName}', '${employment:employerSIDB}'),
    REPLACE(NVL(SHORT_RECRUITER_DESCRIPTION, ''), '${employment:employerName}', '${employment:employerSIDB}'),
    REPLACE(NVL(RECRUITER_DESCRIPTION, ''), '${employment:employerName}', '${employment:employerSIDB}')
FROM INFORMATION_REQUEST_DESCRIPTION
WHERE TEMPLATE_ID = 2245;







