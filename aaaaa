FUNCTION updateByJSON(pcJSON IN CLOB)
RETURN NUMBER
IS

TMP_ALIAS CONSTANT NVARCHAR2(32767) :=
'<alias>
      <name><![CDATA[%NAME%]]></name>
      <language_id><![CDATA[]]></language_id>
    </alias>';
  
TMP_ALIASES CONSTANT NVARCHAR2(32767) :=  
'<?xml version="1.0" encoding="UTF-8"?>
<data>
  <version>1</version>
  <aliases>%ALIASES%</aliases>
</data>
';

  sTmplAlias               NVARCHAR2(32767);
  sTmplFinalAliases        NVARCHAR2(32767);
  sTmplAliases             NVARCHAR2(32767);

  jsonFull JSON_OBJECT_T;
  jsonSource JSON_OBJECT_T;
  sHON VARCHAR2(50);
  sType VARCHAR2(50);
  sStatus VARCHAR2(20);
  nVersion NUMBER;
  
  sOrgName NVARCHAR2(400);
  sOrgNameBase64 VARCHAR2(800);
  sDepartment NVARCHAR2(400);
  sDepartmentBase64 VARCHAR2(800);
  
  sCountry VARCHAR2(50);

  arrAlias JSON_ARRAY_T;
  sAliasName NVARCHAR2(200);
  sAliasNameBase64 VARCHAR2(400);

  sWebsite VARCHAR2(150);
  sNotes NCLOB;
  sDotRegulated  VARCHAR2(1);
  sLastApproverName NVARCHAR2(200); 
  sLastModifierName NVARCHAR2(200);
  
  sMunicipalityBase64 VARCHAR2(200);

  dtLastModified DATE;
  dtLastApproved DATE;
  dtCreated DATE;
  dtLastUsed DATE;
    
  recPostalAddr sdk_postal_address.trecPostalAddress;
  recExistingOrgUnit sdk_contactdb_const.trecOrgUnitInfo;
    
BEGIN

  -- Parse the JSON CLOB into a JSON object
  jsonFull := JSON_OBJECT_T.parse(pcJSON);
  IF jsonFull IS NULL
  THEN
	RETURN NULL;
  END IF;
  
  jsonSource := jsonFull.get_Object('source');
  IF jsonSource IS NULL
  THEN
	RETURN NULL;
  END IF;
  
  -- Extract values from the JSON object
  sHON := convert_honToSidb2Oracle(jsonSource.get_String('hon'));
  sStatus := jsonSource.get_String('status');
  nVersion := 1;
  
  sOrgNameBase64 := jsonSource.get_String('name');
  IF NVL(sOrgNameBase64, ' ') != ' '
  THEN
	sOrgName := decode_base64String(sOrgNameBase64);
  END IF;
  sCountry := jsonSource.get_String('country');
  
  arrAlias := jsonSource.get_Array('aliases');
  IF arrAlias IS NOT NULL 
  THEN
    FOR i IN 0 .. arrAlias.get_size - 1
    LOOP
      sTmplAlias := TMP_ALIAS;
	  
		sAliasNameBase64 := arrAlias.get_string(i);
		IF NVL(sAliasNameBase64, ' ') != ' '
		THEN
			sAliasName := decode_base64String(sAliasNameBase64);
		END IF;  
      inject(sTmplAlias, '%NAME%', sAliasName);
      sTmplFinalAliases := sTmplFinalAliases || sTmplAlias;
    END LOOP;   
  END IF;
  
  sTmplAliases := TMP_ALIASES;
  inject(sTmplAliases, '%ALIASES%', sTmplFinalAliases);
    
	sDepartmentBase64 := jsonSource.get_String('department');
	IF NVL(sDepartmentBase64, ' ') != ' '
	THEN
		sDepartment := decode_base64String(sDepartmentBase64);
	END IF;
  sWebsite := jsonSource.get_String('website');
  sType := jsonSource.get_String('type');

  sNotes := decode_base64(jsonSource.get_Clob('comment'));
    
  sDotRegulated := CASE 
            WHEN jsonSource.get_String('dotRegulated') = 'true' THEN 'Y'
            ELSE 'N'
           END;
  sLastApproverName := jsonSource.get_String('lastApproverName');
  sLastModifierName := jsonSource.get_String('lastModifierName');

  dtLastModified := TO_DATE(SUBSTR(jsonSource.get_String('lastModified'), 1, 19), 'YYYY-MM-DD"T"HH24:MI:SS');
  dtLastApproved := TO_DATE(SUBSTR(jsonSource.get_String('lastApproved'), 1, 19), 'YYYY-MM-DD"T"HH24:MI:SS');
  dtCreated := TO_DATE(SUBSTR(jsonSource.get_String('created'), 1, 19), 'YYYY-MM-DD"T"HH24:MI:SS');
  dtLastUsed := TO_DATE(SUBSTR(jsonSource.get_String('lastUsed'), 1, 19), 'YYYY-MM-DD"T"HH24:MI:SS');

  --"country": "Albania",
  recPostalAddr.country_code := sdk_location.get_countryCodeA2(sdk_location.get_countryId(sCountry));

  sMunicipalityBase64 := jsonSource.get_String('city');
  IF NVL(sMunicipalityBase64, ' ') != ' '
  THEN
	recPostalAddr.nmunicipality := decode_base64String(sMunicipalityBase64);
  END IF;
  
  recPostalAddr.region1 := jsonSource.get_String('region');
  recPostalAddr.postal_code := jsonSource.get_String('postalCode');
  recPostalAddr.address_line := jsonSource.get_String('address');

  recExistingOrgUnit := sdk_contactdb_org_unit_loc.get_info(sHON);

	IF NVL(recPostalAddr.country_code, ' ') != ' '
	THEN
		sdk_postal_address.add_postalAddress(recPostalAddr);
		
		IF recExistingOrgUnit.id IS NULL
		THEN   			
			recExistingOrgUnit.id := contactdb_ou_id_seq.nextval;  
			
			INSERT INTO contactdb_org_unit (
			  id,
			  HON,
			  VERSION,
			  ORG_NAME,
			  DEPT_NAME,
			  website,
			  STATUS,
			  ADDRESS_ID,
			  NOTES,
			  DOT_REGULATED,
			  LAST_APPROVER_NAME,
			  LAST_MODIFIER_NAME,
			  LAST_MODIFIEDDTTM,
			  LAST_APPROVEDDTTM,
			  CREATEDDTTM,
			  LAST_USEDDTTM,
			  aliases
			) 
			VALUES (
			  recExistingOrgUnit.id,
			  sHON,
			  nVersion,
			  sOrgName,
			  sDepartment,
			  sWebsite,
			  sStatus,
			  recPostalAddr.id,
			  sNotes,
			  sDotRegulated,
			  sLastApproverName,
			  sLastModifierName,
			  dtLastModified,
			  dtLastApproved,
			  NVL(dtCreated, SYSDATE),
			  dtLastUsed,
			  sTmplAliases
			);
		ELSE
		  
		  UPDATE contactdb_org_unit 
		  SET
				  VERSION = nVersion,
				  ORG_NAME = sOrgName,
				  DEPT_NAME = sDepartment,
				  website = sWebsite,
				  STATUS = sStatus,
				  ADDRESS_ID = recPostalAddr.id,
				  NOTES = sNotes,
				  DOT_REGULATED = sDotRegulated,
				  LAST_APPROVER_NAME = sLastApproverName,
				  LAST_MODIFIER_NAME = sLastModifierName,
				  LAST_MODIFIEDDTTM = dtLastModified,
				  LAST_APPROVEDDTTM = dtLastApproved,
				  CREATEDDTTM = NVL(dtCreated, SYSDATE),
				  LAST_USEDDTTM = dtLastUsed,
				  aliases = sTmplAliases
				WHERE id = recExistingOrgUnit.id;
		END IF;

		create_additionalInfo(recExistingOrgUnit.id,  sType, jsonSource);
		
		create_automatedServices(recExistingOrgUnit.id, sType, jsonSource);

		create_unitIdentifier(recExistingOrgUnit.id, jsonSource);
		  
		create_phoneFax(recExistingOrgUnit.id, sType, 'contactPhones', 'PHONES', jsonSource);
		
		create_phoneFax(recExistingOrgUnit.id, sType, 'contactFaxes', 'FAXES', jsonSource);
		
		create_emails(recExistingOrgUnit.id,  sType, 'contactEmails', 'EMAILS', jsonSource);
		
		create_websites(recExistingOrgUnit.id,  sType, 'contactWebsites', 'WEBSITES', jsonSource);
		
		create_mails(recExistingOrgUnit.id,  sType, 'contactMails', 'MAILS', jsonSource);
			
		RETURN recExistingOrgUnit.id;

	END IF;

  RETURN null;
  
EXCEPTION
  WHEN OTHERS THEN
    	
	sdk_log_trace.add_error('bdk_contactdb2.updateByJSON',
    						'SIDB2 update error',
                            '',
							pcJSON);	
							
	RAISE;

END updateByJSON;

