PROCEDURE create_phoneFax(pnOrgUnitID IN NUMBER,  psReason IN VARCHAR2, psTag IN VARCHAR2, psType IN VARCHAR2, pjsonOrgUnit IN JSON_OBJECT_T)
IS
TMPL_PHONE_FAX_NUMBER CONSTANT NVARCHAR2(32767) :=
    '<number>
      <country>%COUNTRY%</country>
      <areacode><![CDATA[%AREACODE%]]></areacode>
      <number><![CDATA[%NUMBER%]]></number>
      <ext><![CDATA[%EXT%]]></ext>
      <comment><![CDATA[]]></comment>
      <recipient><![CDATA[]]></recipient>
      <department><![CDATA[]]></department>
    </number>';
  
TMPL_PHONE_FAX CONSTANT NVARCHAR2(32767) :=
	'<?xml version="1.0" encoding="UTF-8"?>
	<data><version>1</version>' || TMPL_COMMON_INFO || '<numbers>%NUMBERS%</numbers></data>';

  sTmplNumber               NVARCHAR2(32767);
  sTmplFinalNumber          NVARCHAR2(32767);
  sTmplFinalNumbers         NVARCHAR2(32767);

  jsonContactObj JSON_OBJECT_T;
  jsonNumbers JSON_ARRAY_T;
  nestedNumber JSON_OBJECT_T;
  countryCode VARCHAR2(10);
  areaCode VARCHAR2(10);
  phoneNumber VARCHAR2(60);
  extension VARCHAR2(20);
  sPriority VARCHAR2(20);
  
BEGIN 
    
    IF pjsonOrgUnit.has(psTag) 
    THEN  
		-- Extract the JSON array
		jsonContactObj := TREAT(pjsonOrgUnit.get(psTag) AS JSON_OBJECT_T);

		IF jsonContactObj IS NULL
		THEN 
			clear_contact(pnOrgUnitID, psReason, psType);
			RETURN;
		END IF;   

		IF jsonContactObj.has('numbers') 
		THEN
			jsonNumbers := TREAT(jsonContactObj.get('numbers') AS JSON_ARRAY_T);
			FOR i IN 0 .. jsonNumbers.get_size - 1
			LOOP
				-- Cast the array element to JSON_OBJECT_T
				nestedNumber := TREAT(jsonNumbers.get(i) AS JSON_OBJECT_T);

				sTmplNumber := TMPL_PHONE_FAX_NUMBER;

				-- Extract fields from the JSON object
				countryCode := nestedNumber.get_string('countryCode');
				inject(sTmplNumber, '%COUNTRY%', countryCode);

				areaCode := nestedNumber.get_string('areaCode');
				inject(sTmplNumber, '%AREACODE%', areaCode);

				phoneNumber := nestedNumber.get_string('number');
				inject(sTmplNumber, '%NUMBER%', phoneNumber);

				extension := nestedNumber.get_string('extension');
				inject(sTmplNumber, '%EXT%', extension);

				sTmplFinalNumber := sTmplFinalNumber || sTmplNumber;

			END LOOP;

			-- Get template
			sTmplFinalNumbers := TMPL_PHONE_FAX;

			update_commonDetails(sTmplFinalNumbers, jsonContactObj, sPriority);

			inject(sTmplFinalNumbers, '%NUMBERS%', sTmplFinalNumber);

			UPDATE CONTACTDB_ORG_UNIT_CONTACT 
			SET DATA = sTmplFinalNumbers, PRIORITY = NVL(TO_NUMBER(sPriority), 0)
			WHERE REASON = psReason AND TYPE = psType AND ORG_UNIT_ID = pnOrgUnitID;	

			IF SQL%ROWCOUNT = 0
			THEN
				INSERT INTO CONTACTDB_ORG_UNIT_CONTACT (ID, NAME, REASON, TYPE, PRIORITY, ORG_UNIT_ID, DATA)
				VALUES (CONTACTDB_OU_CONTACT_ID_SEQ.NEXTVAL, 'undefined', psReason, psType, NVL(TO_NUMBER(sPriority), 0), pnOrgUnitID, sTmplFinalNumbers);
			END IF;
		END IF;
	ELSE
		clear_contact(pnOrgUnitID, psReason, psType);		
	END IF;
       
END create_phoneFax;

