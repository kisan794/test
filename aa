@SuppressWarnings("unchecked")
    private String getAddressLine(Source source) {
        DBObject payload = source.getPayload();
        if (payload != null) {
            Object addressObj = payload.get("address");
            if (addressObj instanceof List) {
                List<?> addresses = (List<?>) addressObj;
                if (!addresses.isEmpty()) {
                    Object firstAddr = addresses.get(0);
                    if (firstAddr instanceof DBObject) {
                        return (String) ((DBObject) firstAddr).get("line");
                    } else if (firstAddr instanceof java.util.Map) {
                        return (String) ((java.util.Map<?, ?>) firstAddr).get("line");
                    }
                }
            }
        }
        return null;
    }
