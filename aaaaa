PROCEDURE put_incrementUsedCount(pnOrderServiceID IN NUMBER, psHon IN VARCHAR2)
IS
	sUrl VARCHAR2(300);
	sJson VARCHAR2(300);
	nValue NUMBER;
	sResponse VARCHAR2(4000);
	b_autoMatch BOOLEAN;
BEGIN
	nValue := is_sidb2(pnOrderServiceID);
	IF nValue != SIDB2_NONE AND NVL(psHon, ' ') != ' '
	THEN
		sUrl := is_domains.get_property
		(
			'BASE',
			'SIDB_HOST'
		);

		sUrl := replace(sUrl, 'https://', 'http://');
		sUrl := sUrl || '/sourceintelligence-service/api/v1/source-organization/increment-used-count';
		b_autoMatch := (nValue <> SIDB2_MANUAL);
		
		sJson := '{"hon":"' || convert_honForMongo(psHon) || '", "autoMatch":' || 
             CASE WHEN b_autoMatch THEN 'true' ELSE 'false' END || '}';
				
		sdk_http.request_varchar(sUrl, sJson, 30, 'application/json', 'UTF-8', 'PUT', sResponse);
	
	END IF;
	
EXCEPTION
  WHEN OTHERS THEN
    	
	sdk_params.init_parameterBuffer;
    sdk_params.set_parameterValue('honID', psHon);
	sdk_params.set_parameterValue('orderServiceID', TO_CHAR(pnOrderServiceID));
	sdk_params.set_parameterValue('sUrl', sUrl);
	sdk_params.set_parameterValue('sJson', sJson);
	sdk_log_trace.add_error('bdk_contactdb2.put_incrementUsedCount',
    						'SIDB2 put error',
                            sdk_params.get_parameterBuffer());	
END put_incrementUsedCount;

END bdk_contactdb2;
