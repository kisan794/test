1.INSERT INTO INFO_REQUEST_TEMPLATE (
    ID,
    TITLE,
    TYPE,
    STATE,
    STATE_DTTM,
    FORMAT,
    OPERATOR_ID,
    PROPERTIES,
    REFERENCE
)
SELECT 
    (SELECT MAX(ID) + 1 FROM INFO_REQUEST_TEMPLATE),
    TITLE,
    TYPE,
    STATE,
    STATE_DTTM,
    FORMAT,
    OPERATOR_ID,
    PROPERTIES,
    REFERENCE
FROM INFO_REQUEST_TEMPLATE
WHERE ID = 2245;

UPDATE info_request_template
SET title = 'INT''L - Unacceptable Employment SIDB2 Documentation received - generic'
WHERE id = '1137022';



2. INSERT INTO INFO_REQUEST_DESCRIPTION (
    ID,
    TEMPLATE_ID,
    SHORT_DESCRIPTION,
    DESCRIPTION,
    LANGUAGE,
    SHORT_APPLICANT_DESCRIPTION,
    APPLICANT_DESCRIPTION
)
SELECT 
(SELECT MAX(ID) + 1 FROM INFO_REQUEST_DESCRIPTION),
    1137022, 
    SHORT_DESCRIPTION,
    DESCRIPTION,
    LANGUAGE,
    SHORT_APPLICANT_DESCRIPTION,
    APPLICANT_DESCRIPTION
FROM INFO_REQUEST_DESCRIPTION
WHERE TEMPLATE_ID = 2245 and language='en';


UPDATE info_request_description
SET 
    short_description = REPLACE(short_description, '$employment:employerName$', '$employment:employerNameSIDB2$'),
    description = REPLACE(description, '$employment:employerName$', '$employment:employerNameSIDB2$'),
    short_applicant_description = REPLACE(short_applicant_description, '$employment:employerName$', '$employment:employerNameSIDB2$'),
    applicant_description = REPLACE(applicant_description, '$employment:employerName$', '$employment:employerNameSIDB2$')
WHERE template_id = '1137022'
  AND language = 'en';



