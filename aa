package com.hireright.sourceintelligence.service.impl;

import com.hireright.sourceintelligence.api.dto.InstitutionRecord;
import com.hireright.sourceintelligence.service.excel.ExcelParserFactory;
import com.hireright.sourceintelligence.service.excel.ExcelParserStrategy;
import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.springframework.stereotype.Service;
import org.springframework.web.multipart.MultipartFile;

import java.io.IOException;
import java.util.List;

import static com.hireright.sourceintelligence.domain.constants.Constants.ExcelParserTypes.INSTITUTION;

@Slf4j
@Service
@RequiredArgsConstructor
public class ExcelParserService {

    private final ExcelParserFactory excelParserFactory;

    public List<InstitutionRecord> parseExcelFile(MultipartFile file) throws IOException {
        return parseExcelFile(file, INSTITUTION);
    }

    public List<InstitutionRecord> parseExcelFile(MultipartFile file, String parserType) throws IOException {
        ExcelParserStrategy<InstitutionRecord> parser = excelParserFactory.getParser(parserType);
        return parser.parse(file);
    }

    public List<String> getSupportedParserTypes() {
        return excelParserFactory.getAvailableParserTypes();
    }

    public boolean isParserTypeSupported(String parserType) {
        return excelParserFactory.hasParser(parserType);
    }
}



package com.hireright.sourceintelligence.service.excel.strategy;

import com.hireright.sourceintelligence.api.dto.InstitutionRecord;
import com.hireright.sourceintelligence.service.excel.ExcelColumnMapping;
import com.hireright.sourceintelligence.service.excel.ExcelParserStrategy;
import com.hireright.sourceintelligence.service.excel.ExcelRowMapper;
import com.hireright.sourceintelligence.service.excel.GenericExcelParser;
import com.hireright.sourceintelligence.service.excel.mapper.InstitutionRowMapper;
import com.hireright.sourceintelligence.service.excel.mapping.InstitutionColumnMapping;
import lombok.RequiredArgsConstructor;
import org.springframework.stereotype.Component;
import org.springframework.web.multipart.MultipartFile;

import java.io.IOException;
import java.util.List;

import static com.hireright.sourceintelligence.domain.constants.Constants.ExcelParserTypes.INSTITUTION;

@Component
@RequiredArgsConstructor
public class InstitutionExcelParserStrategy implements ExcelParserStrategy<InstitutionRecord> {

    private final GenericExcelParser genericExcelParser;
    private final InstitutionRowMapper institutionRowMapper;

    @Override
    public List<InstitutionRecord> parse(MultipartFile file) throws IOException {
        return genericExcelParser.parseExcelFile(file, getColumnMapping(), getRowMapper());
    }

    @Override
    public String getParserType() {
        return INSTITUTION;
    }

    @Override
    public ExcelColumnMapping getColumnMapping() {
        return InstitutionColumnMapping.create();
    }

    @Override
    public ExcelRowMapper<InstitutionRecord> getRowMapper() {
        return institutionRowMapper;
    }
}




package com.hireright.sourceintelligence.service.excel;

import org.springframework.web.multipart.MultipartFile;

import java.io.IOException;
import java.util.List;

public interface ExcelParserStrategy<T> {
    
    List<T> parse(MultipartFile file) throws IOException;
    
    String getParserType();
    
    ExcelColumnMapping getColumnMapping();
    
    ExcelRowMapper<T> getRowMapper();
}



package com.hireright.sourceintelligence.service.excel;

import lombok.extern.slf4j.Slf4j;
import org.springframework.stereotype.Component;

import java.util.List;
import java.util.Map;
import java.util.function.Function;
import java.util.stream.Collectors;

@Slf4j
@Component
public class ExcelParserFactory {

    private final Map<String, ExcelParserStrategy<?>> parserStrategies;

    public ExcelParserFactory(List<ExcelParserStrategy<?>> strategies) {
        this.parserStrategies = strategies.stream()
                .collect(Collectors.toMap(
                        ExcelParserStrategy::getParserType,
                        Function.identity()
                ));
        
        log.info("Initialized ExcelParserFactory with {} parser strategies: {}", 
                parserStrategies.size(), 
                parserStrategies.keySet());
    }

    @SuppressWarnings("unchecked")
    public <T> ExcelParserStrategy<T> getParser(String parserType) {
        ExcelParserStrategy<?> strategy = parserStrategies.get(parserType);
        
        if (strategy == null) {
            throw new IllegalArgumentException(
                    String.format("No parser strategy found for type: %s. Available types: %s", 
                            parserType, 
                            parserStrategies.keySet())
            );
        }
        
        return (ExcelParserStrategy<T>) strategy;
    }

    public boolean hasParser(String parserType) {
        return parserStrategies.containsKey(parserType);
    }

    public List<String> getAvailableParserTypes() {
        return List.copyOf(parserStrategies.keySet());
    }
}

  public static class ExcelParserTypes {
        public static final String INSTITUTION = "institution";
        public static final String ALTERNATIVE_INSTITUTION = "alternative_institution";
        public static final String LICENSE = "license";
    }

