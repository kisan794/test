sequenceDiagram
    participant User
    participant OPTool
    participant SourceIntelligenceService
    participant HRG1

    User->>OPTool: Click "Select"
    OPTool->>SourceIntelligenceService: GET /entryPoint?ot_key={key}&entry={entry}&apiHost={apiHost}
    
    SourceIntelligenceService->>HRG1: GET /access_points/{ot_key}
    
    alt Access Point Success
        HRG1-->>SourceIntelligenceService: 200 OK - User authentication data
        
        SourceIntelligenceService->>HRG1: GET /permissions/{userName}?scope=...
        
        alt Permissions Success
            HRG1-->>SourceIntelligenceService: 200 OK - User permissions
            
            alt User has approver permission
                loop Paginated calls
                    SourceIntelligenceService->>HRG1: GET /approvers?offset={offset}&limit=1000
                    HRG1-->>SourceIntelligenceService: 200 OK - Approvers list
                end
            end
            
            SourceIntelligenceService-->>OPTool: 302 FOUND - Redirect with JWT token
            OPTool-->>User: Redirect to authenticated UI
            
        else Permissions 404
            HRG1-->>SourceIntelligenceService: 404 Not Found
            SourceIntelligenceService-->>OPTool: Error response
            OPTool-->>User: Error displayed
        end
        
    else Access Point 404
        HRG1-->>SourceIntelligenceService: 404 Not Found
        SourceIntelligenceService-->>OPTool: Error response
        OPTool-->>User: Error displayed
    end
