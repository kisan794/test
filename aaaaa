----------------------------------------------------------------	
FUNCTION decode_base64String(InBase64Char IN VARCHAR2) 
RETURN NVARCHAR2 
IS
BEGIN
    IF NVL(InBase64Char, ' ') = ' '
	THEN
        RETURN NULL;
	END IF;
	
    RETURN REPLACE(utl_raw.cast_to_nvarchar2(utl_encode.base64_decode(utl_raw.cast_to_raw(InBase64Char))), UNISTR('\FEFF'), '');
	
END decode_base64String;

----------------------------------------------------------------	
FUNCTION convert_honToSidb2Oracle(psHon IN VARCHAR2) 
RETURN VARCHAR2 
IS
BEGIN
    IF NVL(psHon, ' ') != ' ' AND SUBSTR(psHon, 1, 1) = 'O' THEN
        RETURN '2' || SUBSTR(psHon, 2);
    END IF;
	
    RETURN psHon;
END convert_honToSidb2Oracle;

----------------------------------------------------------------	
FUNCTION convert_honForMongo(psHon IN VARCHAR2) 
RETURN VARCHAR2 
IS
BEGIN
    IF NVL(psHon, ' ') != ' ' AND SUBSTR(psHon, 1, 1) = '2' THEN
        RETURN 'O' || SUBSTR(psHon, 2);
    END IF;
	
    RETURN psHon;
END convert_honForMongo;

---------------------------------------------------------------------------------------
FUNCTION escapeXMLSymbols
(
  psValue IN NVARCHAR2
)
RETURN NVARCHAR2
IS
  sResult NVARCHAR2(32767);

BEGIN
  sResult := regexp_replace(psValue,'['||chr(1)||'-'||chr(8)||']|['||chr(11)||'-'||chr(12)||']|['||chr(14)||'-'||chr(31)||']','');
  sResult := REPLACE(sResult, CHR(127));

  --sResult := REPLACE(sResult, '&', '&amp;');
  --sResult := REPLACE(sResult, '<', '&lt;');
  --sResult := REPLACE(sResult, '>', '&gt;');
  --sResult := REPLACE(sResult, '"', '&quot;');
 -- sResult := REPLACE(sResult, '''', '&apos;');


  RETURN TRIM(sResult);

EXCEPTION
  WHEN OTHERS THEN
    -- Log parameters
    sdk_params.init_parameterBuffer;
    sdk_params.set_parameterValue('psValue', psValue);
    sdk_log_trace.add_error(
      'national_instance_provider.escapeXMLSymbols',
      'Failed.',
      sdk_params.get_parameterBuffer);

  RETURN NULL;
END escapeXMLSymbols;

