PROCEDURE create_automatedServices(pnOrgUnitID IN NUMBER,  psReason IN VARCHAR2, pjsonOrgUnit IN JSON_OBJECT_T)
IS

TMPL_AUTOMATED_BRANCH CONSTANT NVARCHAR2(2000) :=
      '<branch><![CDATA[%BRANCH%]]></branch>';
	  
TMPL_AUTOMATED_CODE CONSTANT NVARCHAR2(2000) :=
      '<code><![CDATA[%CODE%]]></code>';
 
TMPL_AUTOMATED_SERVICE CONSTANT NVARCHAR2(2000) :=
'<service>
	  <provider>%PROVIDER%</provider>
      <codes>
        %CODES%
      </codes>
      <branches>%BRANCHES%</branches>      
      <company_names>
        <company_name><![CDATA[]]></company_name>        
      </company_names>
      <comment><![CDATA[]]></comment>' || TMPL_COMMON_INFO || '</service>';
    
TMPL_AUTOMATED_SERVICES CONSTANT NVARCHAR2(32767) :=
  '<?xml version="1.0" encoding="UTF-8"?>
  <data>
    <version>1</version>
    <services>
      %SERVICES%
    </services>
  </data>';

  
  sTmplFinalBranch        NVARCHAR2(32767);
  sTmplCode               NVARCHAR2(32767);
  sTmplFinalCode          NVARCHAR2(32767);
  sTmplFinalService       NVARCHAR2(32767);
  sTmplService            NVARCHAR2(32767);
  sTmplServices           NVARCHAR2(32767);
  
  jsonArray JSON_ARRAY_T;
  
  i INTEGER;
  j INTEGER;
    
  nestedObj JSON_OBJECT_T;
  	
  provider VARCHAR2(100);
  providerName VARCHAR2(100);
  codesArray JSON_ARRAY_T;
  codeValue VARCHAR2(100);
  sPriority VARCHAR2(20);
  
  psEquifaxHighSchoolDateRange NVARCHAR2(50);
  
BEGIN

  IF pjsonOrgUnit.has('contactAutomatedServices') 
  THEN  
    -- Extract the JSON array
    jsonArray := pjsonOrgUnit.get_array('contactAutomatedServices');
    
    IF jsonArray IS NULL
    THEN 
	clear_contact(pnOrgUnitID, psReason, 'AUTOMATED_SERVICES');		
      RETURN;
    END IF;  

	clear_unitIdentifierForAProvider(pnOrgUnitID);	

    -- Loop through the JSON array
    FOR i IN 0 .. jsonArray.get_size - 1 
    LOOP
		-- Extract nested JSON object as a string             
		nestedObj := TREAT(jsonArray.get(i) AS JSON_OBJECT_T); 
             	      
		create_unitIdentifierForAProvider(pnOrgUnitID, nestedObj, psEquifaxHighSchoolDateRange);
		
		-- Extract values from the nested object
		providerName := nestedObj.get_string('name');
		provider := nestedObj.get_string('provider');
 
		sTmplService := TMPL_AUTOMATED_SERVICE; 
		inject(sTmplService, '%PROVIDER%', provider);
        
		update_commonDetails(sTmplService, nestedObj, sPriority, psEquifaxHighSchoolDateRange);
    
		sTmplFinalService := sTmplFinalService || sTmplService;
              
		sTmplFinalBranch := '';		
		load_array(
			nestedObj,
			TMPL_AUTOMATED_BRANCH,
			sTmplFinalBranch,
			'branches',
			'%BRANCH%'
		);		
		inject(sTmplFinalService, '%BRANCHES%', sTmplFinalBranch);
		
		sTmplFinalCode := '';			  
		
        -- Handle 'codes' which can be an array or a string
        IF nestedObj.has('codes') THEN
            IF nestedObj.get_type('codes') = 'ARRAY' THEN
                codesArray := nestedObj.get_array('codes');
                FOR j IN 0 .. codesArray.get_size - 1 LOOP
                    codeValue := codesArray.get_string(j);
    
                    sTmplCode := TMPL_AUTOMATED_CODE; 
                    inject(sTmplCode, '%CODE%', codeValue);
                    sTmplFinalCode := sTmplFinalCode || sTmplCode;
                END LOOP;
            ELSE
                codeValue := nestedObj.get_string('codes');
                
                sTmplCode := TMPL_AUTOMATED_CODE; 
                inject(sTmplCode, '%CODE%', codeValue);
                sTmplFinalCode := sTmplCode;
            END IF;
        END IF;
        inject(sTmplFinalService, '%CODES%', sTmplFinalCode);
    END LOOP;
      
    -- Get template
    sTmplServices := TMPL_AUTOMATED_SERVICES;
    inject(sTmplServices, '%SERVICES%', sTmplFinalService);
      
	UPDATE CONTACTDB_ORG_UNIT_CONTACT 
	SET DATA = sTmplServices, PRIORITY = NVL(TO_NUMBER(sPriority), 0)
		WHERE REASON = psReason AND TYPE = 'AUTOMATED_SERVICES' AND ORG_UNIT_ID = pnOrgUnitID;	

	IF SQL%ROWCOUNT = 0
	THEN
		INSERT INTO CONTACTDB_ORG_UNIT_CONTACT (ID, NAME, REASON, TYPE, PRIORITY, ORG_UNIT_ID, DATA)
		VALUES (CONTACTDB_OU_CONTACT_ID_SEQ.NEXTVAL, 'undefined', psReason, 'AUTOMATED_SERVICES', NVL(TO_NUMBER(sPriority), 0), pnOrgUnitID, sTmplServices);
	END IF;
	ELSE
		clear_contact(pnOrgUnitID, psReason, 'AUTOMATED_SERVICES');		
	END IF;
    
END create_automatedServices;

