definitions:
  caches:
    sonar: ~/.sonar/cache
    gradle: ~/.gradle

pipelines:
  branches:
    '{dev_azure,dev,test}':

      - step:
          name: Build + Test + Sonar
          image: gradle:8.14.3
          caches:
            - sonar
            - gradle
          runs-on:
            - self.hosted
            - linux
            - azure
          script:
            - gradle clean test jacocoTestReport sonarqube \
              --no-daemon --stacktrace --info \
              -Dsonar.host.url=$SONAR_HOST_URL_DNS_ZONE \
              -Dsonar.login=$SONAR_TOKEN \
              -Dsonar.qualitygate.wait=true
            # Debug (optional)
            - ls -l build/reports/jacoco/test/
          artifacts:
            - build/libs/*.jar
            - build/reports/**

      - step:
          name: Docker Build
          image: docker:20.10.12
          runs-on:
            - self.hosted
            - linux
            - azure
          script:
            - DOCKER_TAG=${BITBUCKET_COMMIT}
            - REGISTRY_FULL_URL="${ACR_REGISTRY}/sourceintelligence-service"

            # safer login
            - echo $ACR_REGISTRY_PASSWORD | docker login $ACR_REGISTRY \
              -u $ACR_REGISTRY_USER --password-stdin

            - docker build -t $REGISTRY_FULL_URL:$DOCKER_TAG .
            - docker push $REGISTRY_FULL_URL:$DOCKER_TAG
          services:
            - docker

      - step:
          name: Deploy
          image: docker:20.10.12
          runs-on:
            - self.hosted
            - linux
            - azure
          script:
            - sh update_manifest.sh
          services:
            - docker



plugins {
    id 'org.springframework.boot' version '3.2.4'
    id 'io.spring.dependency-management' version '1.1.4'
    id 'java'
    id "org.sonarqube" version "5.1.0.4882"
    id 'jacoco'
}

group = 'com.hireright'
version = '0.0.1-SNAPSHOT'
description = ""
sourceCompatibility = '21'

apply from: "gradle/jacoco.gradle"

repositories {
    gradlePluginPortal()
    mavenCentral()

    maven { url 'https://repo.spring.io/release' }
    maven { url 'https://repo.spring.io/milestone' }
    maven { url "https://plugins.gradle.org/m2/" }
