3. Domain Filtering


public boolean isAllowedDomain(String email) {
    String domain = email.substring(email.indexOf('@') + 1);
    // Check blacklist first
    if (blacklistedDomains.contains(domain)) {
        return false;
    }
    // If whitelist exists, check it
    if (!whitelistedDomains.isEmpty()) {
        return whitelistedDomains.contains(domain);
    }
    return true;
}
