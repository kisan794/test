    <xs:sequence>
        <xs:element name="IdValue" type="IdValueType" maxOccurs="unbounded"/>
    </xs:sequence>
    <xs:attribute name="idOwner" type="xs:string" use="optional"/>
</xs:complexType>

<xs:complexType name="IdValueType">
    <xs:simpleContent>
        <xs:extension base="xs:string">
            <xs:attribute name="name" type="xs:string" use="optional"/>
