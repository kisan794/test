private void incrementAllPriorities(List<BasicDBObject> items) {
        // Find max priority value first
        int maxPriority = items.stream()
                .map(item -> item.get(PRIORITY))
                .filter(priorityObj -> priorityObj != null)
                .mapToInt(this::toInt)
                .max()
                .orElse(0);

        int sequenceNumber = maxPriority + 1;

        for (BasicDBObject item : items) {
            Object priorityObj = item.get(PRIORITY);
            if (priorityObj != null) {
                int currentPriority = toInt(priorityObj);
                item.put(PRIORITY, currentPriority + 1);
            } else {
                item.put(PRIORITY, sequenceNumber++);
            }
        }
    }
