PROCEDURE create_additionalInfo(pnOrgUnitID IN NUMBER,  psReason IN VARCHAR2, pjsonOrgUnit IN JSON_OBJECT_T)
IS

TMPL_ADDITIONAL_INFO CONSTANT NVARCHAR2(32767) :=
'<?xml version="1.0" encoding="UTF-8"?>
<data>
  <version>1</version>
  <contact_person_name><![CDATA[%NAME%]]></contact_person_name>
  <contact_person_title><![CDATA[%TITLE%]]></contact_person_title>
  <source_language><![CDATA[%LANGUAGE%]]></source_language>
  <release_type><![CDATA[%RELEASE_TYPE%]]></release_type>
  <release_sub_type/>
  <release_web_address/>
  <contact_time_from><![CDATA[%CONTACT_TIME_FROM%]]></contact_time_from>
  <contact_time_to><![CDATA[%CONTACT_TIME_TO%]]></contact_time_to>
  <contact_timezone_id><![CDATA[%CONTACT_TIMEZONE_ID%]]></contact_timezone_id>
  <do_not_contact>%DO_NOT_CONTACT%</do_not_contact>
  <verification_validation_process><![CDATA[%VERIFICATION_VALIDATION_PROCESS%]]></verification_validation_process>
  <unaccredited>%UNACCREDITED%</unaccredited>
  <information_request_ids>%INFORMATION_REQUEST_IDS%</information_request_ids>
</data>';

  sTmpl                   NVARCHAR2(32767);
  
  sIsUnaccredited VARCHAR2(50);
  sVerificationValidationProcess VARCHAR2(50);
  sRelationshipType VARCHAR2(50);
  sParentCompanyHon VARCHAR2(50);
  sParentCompanyOrInstitution VARCHAR2(128);
  sParentCountry VARCHAR2(50);
  
  recPostalAddrParent sdk_postal_address.trecPostalAddress;
  recExistingOrgUnitParent sdk_contactdb_const.trecOrgUnitInfo;
  		
  arrInformationRequestIds JSON_ARRAY_T;
  sInformationRequestIds VARCHAR2(100);  
  resultInformationRequestIds VARCHAR2(4000);
  
  sName VARCHAR2(100);
  sTitle VARCHAR2(100);
  sLanguage VARCHAR2(50);
  sReleaseType VARCHAR2(50);
  sContactTimeFrom VARCHAR2(50);
  sContactTimeTo VARCHAR2(50);
  sContactTimeZone VARCHAR2(50);
  sDoNotContact VARCHAR2(50);

BEGIN

  -- Get template
  sTmpl := TMPL_ADDITIONAL_INFO;
    
  sName := pjsonOrgUnit.get_String('contactPersonName');
  inject(sTmpl, '%NAME%', sName);
  
  sTitle := pjsonOrgUnit.get_String('contactPersonTitle');
  inject(sTmpl, '%TITLE%', sTitle);
  
  sLanguage := pjsonOrgUnit.get_String('language');
  inject(sTmpl, '%LANGUAGE%', sLanguage);
  
  sReleaseType := pjsonOrgUnit.get_String('releaseType');
  inject(sTmpl, '%RELEASE_TYPE%', sReleaseType);
  
  sContactTimeFrom := pjsonOrgUnit.get_String('contactTimeFrom');
  inject(sTmpl, '%CONTACT_TIME_FROM%', sContactTimeFrom);
  
  sContactTimeTo := pjsonOrgUnit.get_String('contactTimeTo');
  inject(sTmpl, '%CONTACT_TIME_TO%', sContactTimeTo);
    
  sContactTimeZone := pjsonOrgUnit.get_String('contactTimeZone');
  inject(sTmpl, '%CONTACT_TIMEZONE_ID%', sContactTimeZone);
  
  sDoNotContact := pjsonOrgUnit.get_String('doNotContact');
  inject(sTmpl, '%DO_NOT_CONTACT%', sDoNotContact);
  
  sVerificationValidationProcess := pjsonOrgUnit.get_String('verificationValidationProcess');
  inject(sTmpl, '%VERIFICATION_VALIDATION_PROCESS%', sVerificationValidationProcess);
    
  sIsUnaccredited := pjsonOrgUnit.get_String('isUnaccredited');
  inject(sTmpl, '%UNACCREDITED%', sIsUnaccredited);
 
  arrInformationRequestIds := pjsonOrgUnit.get_Array('infoRequestIDs');
  IF arrInformationRequestIds IS NOT NULL 
  THEN
    FOR i IN 0 .. arrInformationRequestIds.get_size - 1 LOOP
    -- Extract each value
    sInformationRequestIds := arrInformationRequestIds.get_string(i);
	
    -- Append the value to the result string with a comma
    IF i > 0 THEN
      resultInformationRequestIds := resultInformationRequestIds || ', ';
    END IF;
    resultInformationRequestIds := resultInformationRequestIds || sInformationRequestIds;
    END LOOP;
  END IF;

  inject(sTmpl, '%INFORMATION_REQUEST_IDS%', resultInformationRequestIds);

	UPDATE CONTACTDB_ORG_UNIT_CONTACT 
		SET DATA = sTmpl
		WHERE REASON = psReason AND  ORG_UNIT_ID = pnOrgUnitID AND TYPE = 'ADDITIONAL_INFO';
		
	IF SQL%ROWCOUNT = 0
	THEN
		INSERT INTO CONTACTDB_ORG_UNIT_CONTACT (ID, NAME, REASON, TYPE, PRIORITY, ORG_UNIT_ID, DATA)
		VALUES (CONTACTDB_OU_CONTACT_ID_SEQ.NEXTVAL, 'undefined', psReason, 'ADDITIONAL_INFO', 0, pnOrgUnitID, sTmpl);
	END IF;
	
	sRelationshipType := pjsonOrgUnit.get_String('relationshipType');
	sParentCompanyHon := convert_honToSidb2Oracle(pjsonOrgUnit.get_String('parentID'));
	sParentCountry := pjsonOrgUnit.get_String('parentCountry');
	
	IF psReason = 'EMPLOYMENT'
	THEN
		sParentCompanyOrInstitution := pjsonOrgUnit.get_String('parentCompany');
	ELSIF psReason = 'EDUCATION'
	THEN 
		sParentCompanyOrInstitution := pjsonOrgUnit.get_String('parentInstitution');
	END IF;
  
	IF NVL(sRelationshipType, ' ') != ' ' AND 
		NVL(sParentCompanyHon, ' ') != ' ' AND 
		NVL(sParentCountry, ' ') != ' ' AND 
		NVL(sParentCompanyOrInstitution, ' ') != ' '
	THEN		
		recExistingOrgUnitParent := sdk_contactdb_org_unit_loc.get_info(sParentCompanyHon);
	  
	  	IF recExistingOrgUnitParent.id IS NULL
		THEN  	
			recPostalAddrParent.country_code := sdk_location.get_countryCodeA2(sdk_location.get_countryId(sParentCountry));
			
			IF NVL(recPostalAddrParent.country_code, ' ') != ' '
			THEN
				sdk_postal_address.add_postalAddress(recPostalAddrParent);
				
				recExistingOrgUnitParent.id := contactdb_ou_id_seq.nextval;  
				
				INSERT INTO contactdb_org_unit (
				  id,
				  HON,
				  ORG_NAME,
				  ADDRESS_ID,
				  status
				) 
				VALUES (
				  recExistingOrgUnitParent.id,
				  sParentCompanyHon,
				  sParentCompanyOrInstitution,
				  recPostalAddrParent.id,
				  'ACTIVE'
				);	
			END IF;				
		END IF;
	 
	  	IF recExistingOrgUnitParent.id IS NOT NULL
		THEN
			UPDATE CONTACTDB_ORG_UNIT_RELATION 
			SET TYPE = sRelationshipType, 
				PARENT_ID = recExistingOrgUnitParent.id
			WHERE CHILD_ID = pnOrgUnitID;
				
			IF SQL%ROWCOUNT = 0
			THEN
				INSERT INTO CONTACTDB_ORG_UNIT_RELATION (ID, TYPE, PARENT_ID, CHILD_ID)
				VALUES (contactdb_ou_rel_id_seq.NEXTVAL,  sRelationshipType, recExistingOrgUnitParent.id, pnOrgUnitID);
			END IF;
		END IF;
	ELSE
		DELETE CONTACTDB_ORG_UNIT_RELATION WHERE CHILD_ID = pnOrgUnitID;
	END IF;
	    
END create_additionalInfo;

