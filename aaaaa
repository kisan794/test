FUNCTION decode_base64(InBase64Char IN CLOB) RETURN NCLOB IS
    ClobLen      INTEGER := DBMS_LOB.GETLENGTH(InBase64Char);
    amount       INTEGER := 1440; -- 4
    read_offset  INTEGER := 1;
    stringBuffer VARCHAR2(1440);
    decoded_part NVARCHAR2(2000);
    res          NCLOB;
BEGIN
    IF InBase64Char IS NULL OR NVL(ClobLen, 0) = 0 THEN
        RETURN NULL;		
    ELSIF ClobLen <= 20000 THEN
        RETURN TO_NCLOB(
            UTL_RAW.CAST_TO_NVARCHAR2(
                UTL_ENCODE.BASE64_DECODE(
                    UTL_RAW.CAST_TO_RAW(DBMS_LOB.SUBSTR(InBase64Char, ClobLen, 1))
                )
            )
        );
    END IF;

    DBMS_LOB.CREATETEMPORARY(res, TRUE);
    LOOP
        EXIT WHEN read_offset > ClobLen;
        stringBuffer := REPLACE(REPLACE(DBMS_LOB.SUBSTR(InBase64Char, amount, read_offset), CHR(13), NULL), CHR(10), NULL);
        IF stringBuffer IS NOT NULL THEN
            decoded_part := UTL_RAW.CAST_TO_NVARCHAR2(
                UTL_ENCODE.BASE64_DECODE(
                    UTL_RAW.CAST_TO_RAW(stringBuffer)
                )
            );
            DBMS_LOB.WRITEAPPEND(res, LENGTH(decoded_part), decoded_part);
        END IF;
        read_offset := read_offset + amount;
    END LOOP;

    RETURN res;
END decode_base64;

