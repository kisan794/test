PROCEDURE create_mails(pnOrgUnitID IN NUMBER,  psReason IN VARCHAR2, psTag IN VARCHAR2, psType IN VARCHAR2, pjsonOrgUnit IN JSON_OBJECT_T)
IS
TMPL_MAIL CONSTANT NVARCHAR2(32767) :=
    '<address>
      <address_line><![CDATA[%ADDRESS_LINE%]]></address_line>
      <municipality><![CDATA[%MUNICIPALITY%]]></municipality>
      <country>%COUNTRY%</country>
	  <postal_code><![CDATA[%POSTAL_CODE%]]></postal_code>
      <region><![CDATA[%REGION%]]></region>
    </address>';
  
TMPL_MAILS CONSTANT NVARCHAR2(32767) :=
	'<?xml version="1.0" encoding="UTF-8"?>
	<data><version>1</version> ' || TMPL_COMMON_INFO || '<addresses>%ADDRESSES%</addresses></data>';

  sTmplAddress               NVARCHAR2(32767);
  sTmplFinalAddress          NVARCHAR2(32767);
  sTmplFinalAddresses         NVARCHAR2(32767);

  jsonContactObj JSON_OBJECT_T;
  jsonAddresses JSON_ARRAY_T;
  nestedAddress JSON_OBJECT_T;
  address_line VARCHAR2(128);
  municipality NVARCHAR2(128);
  country VARCHAR2(100);
  postal_code VARCHAR2(15);
  region VARCHAR2(128);
  sPriority VARCHAR2(20);
  
BEGIN 
    
  IF pjsonOrgUnit.has(psTag) 
  THEN  
    -- Extract the JSON array
    jsonContactObj := TREAT(pjsonOrgUnit.get(psTag) AS JSON_OBJECT_T);
     
    IF jsonContactObj IS NULL
    THEN 
		clear_contact(pnOrgUnitID, psReason, psType);		
      RETURN;
    END IF;   
    
	IF jsonContactObj.has('addresses') 
	THEN
		jsonAddresses := TREAT(jsonContactObj.get('addresses') AS JSON_ARRAY_T);
	
		FOR i IN 0 .. jsonAddresses.get_size - 1
		LOOP
			-- Cast the array element to JSON_OBJECT_T
			nestedAddress := TREAT(jsonAddresses.get(i) AS JSON_OBJECT_T);

			sTmplAddress := TMPL_MAIL;
			
			-- Extract fields from the JSON object
			address_line := nestedAddress.get_string('address');
			inject(sTmplAddress, '%ADDRESS_LINE%', address_line);
			
			municipality := decode_base64String(nestedAddress.get_string('city'));
			inject(sTmplAddress, '%MUNICIPALITY%', municipality);
			
			country := nestedAddress.get_string('country');
			IF NVL(country, ' ') = ' '
			THEN
				country := '1';				
			ELSE
				country := NVL(TO_CHAR(sdk_location.get_countryId(country)), '1');
			END IF;
				
			inject(sTmplAddress, '%COUNTRY%', country);
		
			postal_code := nestedAddress.get_string('postalCode');
			inject(sTmplAddress, '%POSTAL_CODE%', postal_code);
			
			region := nestedAddress.get_string('region');
			inject(sTmplAddress, '%REGION%', region);

			sTmplFinalAddress := sTmplFinalAddress || sTmplAddress;
		  
		 END LOOP;
	  
		-- Get template
		sTmplFinalAddresses := TMPL_MAILS;
		  
		update_commonDetails(sTmplFinalAddresses, jsonContactObj, sPriority);

		inject(sTmplFinalAddresses, '%ADDRESSES%', sTmplFinalAddress);

		UPDATE CONTACTDB_ORG_UNIT_CONTACT 
		SET DATA = sTmplFinalAddresses, PRIORITY = NVL(TO_NUMBER(sPriority), 0)
		WHERE REASON = psReason AND TYPE = psType AND ORG_UNIT_ID = pnOrgUnitID;	

		IF SQL%ROWCOUNT = 0
		THEN
			INSERT INTO CONTACTDB_ORG_UNIT_CONTACT (ID, NAME, REASON, TYPE, PRIORITY, ORG_UNIT_ID, DATA)
		   VALUES (CONTACTDB_OU_CONTACT_ID_SEQ.NEXTVAL, 'undefined', psReason, psType, NVL(TO_NUMBER(sPriority), 0), pnOrgUnitID, sTmplFinalAddresses);
		END IF;	
		
    END IF;

  ELSE
	clear_contact(pnOrgUnitID, psReason, psType);		
  END IF;
       
END create_mails;

