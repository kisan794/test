#mongodb properties
spring.data.mongodb.uri=mongodb://${mongoUser}:${mongoPass}@${mongoUrl}/${mongoDatabase:sidb}?${mongoProperties}
spring.data.mongodb.database=${mongoDatabase:sidb}

# Transaction timeout configuration (in seconds)
# Default: 300 seconds (5 minutes) per batch transaction
# For 42K records with batch size 300: ~140 batches * 5 min = safe processing time
spring.transaction.default-timeout=300
#actuator properties
management.endpoints.web.base-path=/sourceintelligence-service/actuator
management.endpoints.web.exposure.include=*
management.endpoint.health.show-details=always
management.endpoint.health.probes.enabled=true
management.health.livenessState.enabled=true
management.health.readinessState.enabled=true
#openapi properties
springdoc.swagger-ui.path=/sourceintelligence-service/swagger-ui.html
# Base paths for different API versions
api.v1.base-path=/sourceintelligence-service/api/v1/**
api.v2.base-path=/si/v2/**
springdoc.api-docs.path=/sourceintelligence-service/api-docs
spring.sleuth.otel.config.trace-id-ratio-based=1.0
spring.zipkin.enabled=false
#Spring jackson properties
spring.jackson.serialization.fail-on-empty-beans=false
spring.jackson.mapper.ACCEPT_CASE_INSENSITIVE_ENUMS=true
#Open Telemetry Logging
logging.level.com.hireright.sourceintelligence.config.CustomRequestLoggingFilter=DEBUG
logging.level.org.springframework.web.filter.CommonsRequestLoggingFilter=DEBUG
logging.pattern.console=%d{yy-MM-dd E HH:mm:ss.SSS} %-5p ${PID} --- [%8.15t] %-40.40logger{0} :%m %n

uas.users.url=${UASUsersEndpoint}
outOfBusiness.enabled=${outOfBusinessEnabled}
approvalWorkFlow.disabled=${approvalWorkFlowDisabled}
shard.location=${shardLocation}
jaroWinklerAlgo.distance.threshold=${jaroWinklerDistanceThreshold}

#Kafka topic
si.outOfBusiness.topic=com.hireright.sourceintelligence.outofbusiness${topicSuffix:}

#kafka properties
spring.kafka.listener.ack-mode=manual-immediate
spring.kafka.properties.sasl.jaas.config=org.apache.kafka.common.security.plain.PlainLoginModule required username='${kafkaBrokerUser}' password='${kafkaBrokerPass}';
spring.kafka.properties.schema.registry.basic.auth.user.info=${kafkaSchemaUser}:${kafkaSchemaPass}
spring.kafka.properties.ssl.endpoint.identification.algorithm=https
spring.kafka.properties.schema.registry.url=https://${kafkaSchemaUrl}
spring.kafka.properties.basic.auth.credentials.source=USER_INFO
spring.kafka.bootstrap-servers=${kafkaBrokerUrl}
spring.kafka.properties.security.protocol=SASL_SSL
spring.kafka.properties.request.timeout.ms=20000
spring.kafka.properties.retry.backoff.ms=500
spring.kafka.properties.sasl.mechanism=PLAIN
spring.kafka.properties.spring.deserializer.key.delegate.class=org.apache.kafka.common.serialization.StringDeserializer
spring.kafka.properties.spring.deserializer.value.delegate.class=io.confluent.kafka.serializers.KafkaAvroDeserializer
spring.kafka.producer.key-serializer=org.apache.kafka.common.serialization.StringSerializer
spring.kafka.producer.value-serializer=io.confluent.kafka.serializers.KafkaAvroSerializer

# External API URL
hrg1.api.url=${hrg1API}
hrg1.permission.url=${hrgPermissionAPI}
hrg1.approvers.url=${hrgApproversAPI}
hrg1.permission.url.US=${hrgPermissionAPIUS}
hrg1.approvers.url.US=${hrgApproversAPIUS}
region.threshold.api.url=${regionThresholdAPI}

hrg1.operators.url=${hrgOperatorsAPI}
hrg1.operators.url.US=${hrgOperatorsAPIUS}

# React UI Redirect URL
react.ui.url=${reactReDirectUrl}

# Trust score
user.trust.score=95

# DMS URL
dms.url=${dmsUrl}

# Permissions from optool
hrg1.permissions.scope=${permissionsFromOptool}
spring.elasticsearch.uris=${elasticsearchUri}
spring.elasticsearch.username=${elasticsearchUserName}
spring.elasticsearch.password=${elasticsearchPassword}
elasticsearchEnvType=${elasticsearchEnvType}
management.health.elasticsearch.enabled=false
suggestionThreshold=${suggestionThreshold}
spring.data.elasticsearch.mapping.enable-type-hint=false
logging.level.org.springframework.data.elasticsearch=DEBUG
logging.level.org.elasticsearch.client=DEBUG

server.compression.enabled=true
server.compression.mime-types=application/json
server.compression.min-response-size=10240

# Turn off RestClient debug logs
logging.level.org.elasticsearch.client.RestClient=ERROR
logging.level.org.elasticsearch.client.RestClient.*=ERROR

# Turn off Sniffer logs
logging.level.org.elasticsearch.client.sniff.Sniffer=ERROR
logging.level.org.elasticsearch.client.sniff.*=ERROR

data.extraction.file.max-size-mb=${dataExtractionFileMaxSizeMB:10}


