                .notificationType(NotificationType.EMAIL)
                .async(true)
                .requestId("welcome-" + user.getId())
                .emailNotification(emailDTO)
                .build();
            
            try {
                notificationService.sendNotification(request);
                log.info("Welcome email queued for user: {}", user.getId());
            } catch (Exception e) {
                log.error("Failed to queue email for user: {}", user.getId(), e);
            }
        });
    }
}
