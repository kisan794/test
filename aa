package com.hireright.sourceintelligence.config;

import org.springframework.boot.web.client.RestTemplateBuilder;
import org.springframework.context.annotation.Bean;
import org.springframework.context.annotation.Configuration;
import org.springframework.web.client.RestTemplate;

import java.time.Duration;

@Configuration
public class RestTemplateConfig {

    @Bean("defaultRestTemplate")
    public RestTemplate restTemplate(RestTemplateBuilder builder) {
        return builder
                .setConnectTimeout(Duration.ofSeconds(10))
                .setReadTimeout(Duration.ofSeconds(30))
                .build();
    }

    @Bean("longTimeoutRestTemplate")
    public RestTemplate longTimeoutRestTemplate(RestTemplateBuilder builder) {
        return builder
                .setConnectTimeout(Duration.ofSeconds(15))
                .setReadTimeout(Duration.ofSeconds(60))  // For slower APIs
                .build();
    }
}


@Qualifier("defaultRestTemplate")
private final RestTemplate restTemplate;

// Or for DMS uploads:
@Qualifier("longTimeoutRestTemplate")
