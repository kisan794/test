@Slf4j
@Component
@RequiredArgsConstructor
public class ParchmentDataExtractionProcessor implements DataExtractionProcessor {

    /**
     * Batch size for processing records.
     * Aggressive optimization for 42K+ records:
     *   - 1000 = ~42 batches, ~2-3 min total (if indexed)
     *   - 1500 = ~28 batches, ~1-2 min total (recommended for dedicated DB)
     *   - 2000 = ~21 batches, ~1 min total (max safe size)
     *
     * IMPORTANT: Requires MongoDB indexes on (state, city, country, organizationName)
     */
    private static final int BATCH_SIZE = 1500; // Aggressive optimization for 42K records

    private final VendorsRepository vendorsRepository;
    private final MongoTemplate mongoTemplate;
    private final ElasticsearchService elasticsearchService;

    @Override
    public String getDataExtractionTypeType() {
        return DATA_EXTRACTION_TYPE_PARCHMENT;
    }

    @Override
    public Map<String, Object> processInstitutionRecords(List<ParchmentRecord> parchmentRecordList) {
        Vendors vendor = findParchmentVendor();
        List<String> notFoundInstitutions = Collections.synchronizedList(new ArrayList<>());

        int updatedRecords = 0;
        int totalSourcesUpdated = 0;

        log.info("Starting batch processing of {} institution records (batch size: {})",
                parchmentRecordList.size(), BATCH_SIZE);

        // Process records in batches with separate transactions for each batch
        for (int i = 0; i < parchmentRecordList.size(); i += BATCH_SIZE) {
            int end = Math.min(i + BATCH_SIZE, parchmentRecordList.size());
            List<ParchmentRecord> batch = parchmentRecordList.subList(i, end);

            log.info("Processing batch {}-{} of {} ({}% complete)",
                    i + 1, end, parchmentRecordList.size(),
                    (int)((i / (double)parchmentRecordList.size()) * 100));

            try {
                // Process batch in a separate transaction to avoid timeout
                BatchProcessingResult batchResult = processBatchWithTransaction(batch, vendor, notFoundInstitutions);
                updatedRecords += batchResult.updatedRecords();
                totalSourcesUpdated += batchResult.totalSourcesUpdated();

                log.info("Batch {}-{} completed: {} records matched, {} sources updated",
                        i + 1, end, batchResult.updatedRecords(), batchResult.totalSourcesUpdated());

            } catch (Exception e) {
                log.error("Error processing batch {}-{}, attempting fallback", i + 1, end, e);
                // Fallback to individual processing for this batch
                for (ParchmentRecord parchmentRecord : batch) {
                    try {
                        String stateFullName = resolveStateName(parchmentRecord.getStateCountyRegion());
                        List<Source> matchingSources = findMatchingInstitutions(parchmentRecord, stateFullName);

                        if (!CollectionUtils.isEmpty(matchingSources)) {
                            updatedRecords++;
                            int sourcesUpdated = processSingleRecordWithTransaction(matchingSources, parchmentRecord, vendor);
                            totalSourcesUpdated += sourcesUpdated;
                        } else {
                            notFoundInstitutions.add(formatNotFoundEntry(parchmentRecord, stateFullName));
                        }
                    } catch (Exception ex) {
                        log.error("Error processing institutionRecord: {}", parchmentRecord.getInstitutionName(), ex);
                        notFoundInstitutions.add(parchmentRecord.getInstitutionName() + " (Error: " + ex.getMessage() + ")");
                    }
                }
            }
        }

        log.info("All batches completed. Total: {}, Matched: {}, Updated: {}, NotFound: {}",
                parchmentRecordList.size(), updatedRecords, totalSourcesUpdated, notFoundInstitutions.size());

        return buildProcessingResult(parchmentRecordList.size(), updatedRecords, totalSourcesUpdated, notFoundInstitutions);
    }

    /**
     * Process a single batch within a separate transaction.
     * This prevents long-running transactions that can timeout.
     */
    @Transactional(timeout = 300) // 5 minutes max per batch
    private BatchProcessingResult processBatchWithTransaction(
            List<ParchmentRecord> batch,
            Vendors vendor,
            List<String> notFoundInstitutions) {

        Map<String, List<Source>> sourcesToSaveByCollection = new HashMap<>();
        int updatedRecords = 0;
        int totalSourcesUpdated = 0;

        try {
            // Fetch all matching sources for the batch in a single DB call
            Map<String, List<Source>> batchMatches = findMatchingInstitutionsBatch(batch);

            // Process each record with its pre-fetched matches
            for (ParchmentRecord parchmentRecord : batch) {
                try {
                    String stateFullName = resolveStateName(parchmentRecord.getStateCountyRegion());
                    String recordKey = generateRecordKey(parchmentRecord, stateFullName);
                    List<Source> matchingSources = batchMatches.getOrDefault(recordKey, Collections.emptyList());

                    if (!CollectionUtils.isEmpty(matchingSources)) {
                        updatedRecords++;
                        totalSourcesUpdated += processMatchingSources(matchingSources, parchmentRecord, vendor, sourcesToSaveByCollection);

                        if (matchingSources.size() > 1) {
                            log.debug("Multiple matches for '{}': {} institutionRecordList updated",
                                    parchmentRecord.getInstitutionName(), matchingSources.size());
                        }
                    } else {
                        notFoundInstitutions.add(formatNotFoundEntry(parchmentRecord, stateFullName));
                        log.debug("No match found for: {}", parchmentRecord.getInstitutionName());
                    }
                } catch (Exception e) {
                    log.error("Error processing institutionRecord: {}", parchmentRecord.getInstitutionName(), e);
                    notFoundInstitutions.add(parchmentRecord.getInstitutionName() + " (Error: " + e.getMessage() + ")");
                }
            }

            // Perform bulk save within this transaction (MongoDB only)
            performBulkSaveMongoDB(sourcesToSaveByCollection);

            // Note: Elasticsearch update happens after transaction commit (see below)

        } catch (Exception e) {
            log.error("Error in batch processing transaction", e);
            throw e;
        }

        // Update Elasticsearch AFTER MongoDB transaction commits
        // This prevents ES failures from rolling back MongoDB changes
        // and keeps transaction time minimal
        try {
            updateElasticsearch(sourcesToSaveByCollection);
        } catch (Exception e) {
            // ES failure doesn't fail the batch - can be synced later
            log.error("Elasticsearch update failed for batch (MongoDB saved successfully)", e);
        }

        return new BatchProcessingResult(updatedRecords, totalSourcesUpdated);
    }

    /**
     * Process a single record within its own transaction (fallback for errors).
     */
    @Transactional(timeout = 30) // 30 seconds max per record
    private int processSingleRecordWithTransaction(
            List<Source> matchingSources,
            ParchmentRecord parchmentRecord,
            Vendors vendor) throws IOException {

        Map<String, List<Source>> sourcesToSaveByCollection = new HashMap<>();
        int count = processMatchingSources(matchingSources, parchmentRecord, vendor, sourcesToSaveByCollection);

        if (!sourcesToSaveByCollection.isEmpty()) {
            performBulkSaveMongoDB(sourcesToSaveByCollection);
            updateElasticsearch(sourcesToSaveByCollection);
        }

        return count;
    }

    /**
     * Result object for batch processing.
     */
    private record BatchProcessingResult(int updatedRecords, int totalSourcesUpdated) {
    }

    /**
     * Optimized vendor lookup using direct query instead of loading all vendors.
     */
    private Vendors findParchmentVendor() {
        return vendorsRepository.findByVendor(PARCHMENT_EXCHANGE)
                .orElseThrow(() -> new RuntimeException(String.format(ERROR_VENDOR_NOT_FOUND_TEMPLATE, PARCHMENT_EXCHANGE)));
    }

    private String resolveStateName(String stateInput) {
        String stateFullName = StateMapper.getFullName(stateInput);
        return stateFullName.isEmpty() && !stateInput.isEmpty() ? stateInput : stateFullName;
    }

    private int processMatchingSources(List<Source> sources, ParchmentRecord parchmentRecord,
                                       Vendors vendor, Map<String, List<Source>> sourcesToSaveByCollection) {
        int count = 0;
        for (Source source : sources) {
            boolean wasUpdated = updateParchmentExchangeContact(source, parchmentRecord, vendor);
            if (wasUpdated) {
                String collectionName = "education_source_parchment_test";
                sourcesToSaveByCollection.computeIfAbsent(collectionName, k -> new ArrayList<>()).add(source);
                count++;
            } else {
                log.debug("Skipping DB update for source: {} (HON: {}) - Parchment Exchange already exists",
                        source.getOrganizationName(), source.getHon());
            }
        }
        return count;
    }

    private String formatNotFoundEntry(ParchmentRecord parchmentRecord, String stateFullName) {
        return String.format(LOG_NOT_FOUND_TEMPLATE,
                parchmentRecord.getInstitutionName(), parchmentRecord.getCity(), stateFullName, parchmentRecord.getCountry());
    }

    private Map<String, Object> buildProcessingResult(int totalRecords, int updatedRecords,
                                                      int totalSourcesUpdated, List<String> notFoundInstitutions) {
        Map<String, Object> result = new HashMap<>();
        result.put(RESULT_KEY_TOTAL_RECORDS, totalRecords);
        result.put(RESULT_KEY_UPDATED_RECORDS, updatedRecords);
        result.put(RESULT_KEY_TOTAL_SOURCES_UPDATED, totalSourcesUpdated);
        result.put(RESULT_KEY_NOT_FOUND_RECORDS, notFoundInstitutions.size());
        result.put(RESULT_KEY_NOT_FOUND_INSTITUTIONS, notFoundInstitutions);

        log.info("Processing complete - total: {}, matched: {}, dbUpdated: {}, notFound: {}",
                totalRecords, updatedRecords, totalSourcesUpdated, notFoundInstitutions.size());

        return result;
    }

    /**
     * Perform bulk save to MongoDB only (within transaction).
     */
    private void performBulkSaveMongoDB(Map<String, List<Source>> sourcesToSaveByCollection) {
        sourcesToSaveByCollection.forEach((collectionName, sources) -> {
            if (!sources.isEmpty()) {
                log.info("Bulk saving {} sources to MongoDB collection: {}", sources.size(), collectionName);
                executeBulkUpdate(collectionName, sources);
            }
        });
    }

    /**
     * Update Elasticsearch separately (outside MongoDB transaction to avoid timeout).
     * This is called after MongoDB transaction commits successfully.
     */
    private void updateElasticsearch(Map<String, List<Source>> sourcesToSaveByCollection) {
        sourcesToSaveByCollection.forEach((collectionName, sources) -> {
            if (!sources.isEmpty()) {
                try {
                    log.info("Updating Elasticsearch for {} sources", sources.size());
                    String indexName = Helper.getIndexName(sources.getFirst().getOrganizationType().getType());
                    elasticsearchService.bulkUpdateAutomatedService(indexName, sources);
                } catch (IOException e) {
                    // Log error but don't fail the entire batch - Elasticsearch can be synced later
                    log.error("Failed to update Elasticsearch for {} sources in collection {}. MongoDB is updated successfully.",
                            sources.size(), collectionName, e);
                }
            }
        });
    }

    private void executeBulkUpdate(String collectionName, List<Source> sources) {
        BulkOperations bulkOps = mongoTemplate.bulkOps(BulkOperations.BulkMode.UNORDERED, collectionName);

        sources.forEach(source -> {
            Query query = new Query(Criteria.where(MONGO_FIELD_ID).is(source.getId()));
            Update update = new Update()
                    .set(FIELD_PAYLOAD, source.getPayload());
            bulkOps.upsert(query, update);
        });

        var result = bulkOps.execute();
        log.info("Bulk save completed - collection: {}, modified: {}, upserted: {}",
                collectionName, result.getModifiedCount(), result.getUpserts().size());
    }

    /**
     * Optimized batch query to fetch all matching institutions in a single DB call.
     * This reduces N database calls to just 1 call per batch.
     * Uses projection to fetch only required fields for matching.
     * Uses $or with location + name combinations to minimize result set size.
     */
    private Map<String, List<Source>> findMatchingInstitutionsBatch(List<ParchmentRecord> batch) {
        if (batch.isEmpty()) {
            return Collections.emptyMap();
        }

        // Build $or criteria for all unique location + name combinations
        List<Criteria> recordCriteriaList = new ArrayList<>();

        for (ParchmentRecord record : batch) {
            String stateFullName = resolveStateName(record.getStateCountyRegion());
            if (stateFullName == null || stateFullName.isEmpty()) {
                continue;
            }

            // Build location criteria
            Criteria locationCriteria = buildLocationCriteria(record, stateFullName);

            // Build name criteria (organizationName OR organizationAlias)
            Criteria nameCriteria = buildNameCriteria(record.getInstitutionName());

            // Combine: (locationMatch AND nameMatch) - this is very precise!
            Criteria combinedCriteria = new Criteria().andOperator(locationCriteria, nameCriteria);

            recordCriteriaList.add(combinedCriteria);
        }

        if (recordCriteriaList.isEmpty()) {
            log.warn("No valid criteria found in batch");
            return Collections.emptyMap();
        }

        // Single database query with $or for all (location + name) combinations
        // This is HIGHLY optimized - fetches only sources that match BOTH location AND name
        Query query = new Query(new Criteria().orOperator(recordCriteriaList.toArray(new Criteria[0])));

        // Use projection to fetch only the fields needed for matching + payload update
        query.fields()
                .include(MONGO_FIELD_ID)        // _id needed for update
                .include(FIELD_NAME)             // organizationName for matching
                .include(FIELD_ALIAS)            // organizationAlias for matching
                .include(FIELD_CITY)             // city for matching
                .include(FIELD_STATE)            // state for matching
                .include(FIELD_COUNTRY)          // country for matching
                .include(FIELD_HON)              // hon for logging
                .include(FIELD_TYPE)             // organizationType for collection name
                .include(FIELD_PAYLOAD);         // payload for update

        List<Source> allSources = mongoTemplate.find(query, Source.class, "education_source_parchment_test");

        log.info("Batch query returned {} sources for {} record combinations (location+name, with projection)",
                 allSources.size(), recordCriteriaList.size());

        // Group sources by matching records (in-memory matching for name)
        Map<String, List<Source>> resultMap = new HashMap<>();

        for (ParchmentRecord record : batch) {
            String stateFullName = resolveStateName(record.getStateCountyRegion());
            String recordKey = generateRecordKey(record, stateFullName);

            List<Source> matchingSources = allSources.stream()
                    .filter(source -> matchesRecord(source, record, stateFullName))
                    .collect(Collectors.toList());

            if (!matchingSources.isEmpty()) {
                log.debug("Found {} matches for institution '{}'", matchingSources.size(), record.getInstitutionName());
            }

            resultMap.put(recordKey, matchingSources);
        }

        return resultMap;
    }

    /**
     * Fallback method for individual institution lookup (used in error scenarios).
     */
    private List<Source> findMatchingInstitutions(ParchmentRecord parchmentRecord, String stateFullName) {
        Criteria locationCriteria = buildLocationCriteria(parchmentRecord, stateFullName);
        Criteria nameCriteria = buildNameCriteria(parchmentRecord.getInstitutionName());

        Query query = new Query(new Criteria().andOperator(nameCriteria, locationCriteria));
        List<Source> sources = mongoTemplate.find(query, Source.class, "education_source_parchment_test");

        if (!CollectionUtils.isEmpty(sources)) {
            log.info("Found {} matches for institution '{}'", sources.size(), parchmentRecord.getInstitutionName());
        }

        return sources;
    }

    /**
     * Generate a unique key for each record to map it to its matching sources.
     */
    private String generateRecordKey(ParchmentRecord record, String stateFullName) {
        return String.format("%s|%s|%s|%s",
                normalizeString(record.getInstitutionName()),
                normalizeString(record.getCity()),
                normalizeString(stateFullName),
                normalizeString(record.getCountry()));
    }

    /**
     * Check if a source matches a parchment record based on location and name criteria.
     */
    private boolean matchesRecord(Source source, ParchmentRecord record, String stateFullName) {
        // Location match
        if (!stateFullName.equals(source.getState())) {
            return false;
        }

        if (!matchesPattern(source.getCity(), buildRegexPattern(record.getCity()))) {
            return false;
        }

        if (!matchesPattern(source.getCountry(), buildRegexPattern(record.getCountry()))) {
            return false;
        }

        // Name match (organizationName or organizationAlias)
        String namePattern = buildRegexPattern(record.getInstitutionName());

        if (matchesPattern(source.getOrganizationName(), namePattern)) {
            return true;
        }

        // Check aliases
        if (source.getOrganizationAlias() != null) {
            for (Alias alias : source.getOrganizationAlias()) {
                if (alias != null && alias.getName() != null && matchesPattern(alias.getName(), namePattern)) {
                    return true;
                }
            }
        }

        return false;
    }

    /**
     * Check if a value matches a regex pattern (case-insensitive).
     */
    private boolean matchesPattern(String value, String regexPattern) {
        if (value == null || regexPattern == null) {
            return false;
        }
        try {
            Pattern pattern = Pattern.compile(regexPattern, Pattern.CASE_INSENSITIVE);
            return pattern.matcher(value).matches();
        } catch (Exception e) {
            log.warn("Invalid regex pattern: {}", regexPattern, e);
            return false;
        }
    }

    /**
     * Normalize string for consistent key generation.
     */
    private String normalizeString(String value) {
        return value == null ? "" : value.trim().toLowerCase();
    }

    /**
     * OPTIMIZED: Use exact match instead of regex where possible.
     * Regex is 10-20x slower than exact match in MongoDB.
     */
    private Criteria buildLocationCriteria(ParchmentRecord parchmentRecord, String stateFullName) {
        // State: always exact match (fastest)
        Criteria stateCriteria = Criteria.where(FIELD_STATE).is(stateFullName);

        // City & Country: Use case-insensitive exact match instead of regex
        // This allows MongoDB to use indexes much more efficiently
        String city = parchmentRecord.getCity();
        String country = parchmentRecord.getCountry();

        if (city != null && !city.isEmpty()) {
            // Case-insensitive match using regex only for anchored match
            stateCriteria.and(FIELD_CITY).regex("^" + Pattern.quote(city) + "$", "i");
        }

        if (country != null && !country.isEmpty()) {
            stateCriteria.and(FIELD_COUNTRY).regex("^" + Pattern.quote(country) + "$", "i");
        }

        return stateCriteria;
    }

    /**
     * OPTIMIZED: Build name criteria with better index utilization.
     */
    private Criteria buildNameCriteria(String institutionName) {
        if (institutionName == null || institutionName.isEmpty()) {
            return new Criteria();
        }

        // Use regex with anchors for precise matching
        String namePattern = "^" + Pattern.quote(institutionName) + "$";

        return new Criteria().orOperator(
                Criteria.where(FIELD_NAME).regex(namePattern, "i"),
                Criteria.where(MONGO_FIELD_ORGANIZATION_ALIAS_NAME).regex(namePattern, "i")
        );
    }

    /**
     * DEPRECATED: Use Pattern.quote() instead for better performance.
     * Kept for backward compatibility with in-memory matching.
     */
    private String buildRegexPattern(String value) {
        if (value == null || value.isEmpty()) {
            return "";
        }
        return "^" + Pattern.quote(value) + "$";
    }

    private String escapeRegex(String input) {
        return (input == null || input.isEmpty()) ? input : Pattern.quote(input);
    }

    private boolean updateParchmentExchangeContact(Source source, ParchmentRecord parchmentRecord, Vendors vendor) {
        BasicDBObject payload = ensurePayload(source);
        List<BasicDBObject> contacts = ensureContacts(payload);
        BasicDBObject contact = ensureContact(contacts);
        List<BasicDBObject> contactDetails = ensureContactDetails(contact);
        BasicDBObject automatedServicesContact = ensureAutomatedServicesContact(contactDetails);

        return updateParchmentExchangeCommunication(automatedServicesContact, parchmentRecord, vendor);
    }

    private List<BasicDBObject> toBasicDBObjectList(Object obj) {
        return switch (obj) {
            case null -> new ArrayList<>();
            case List<?> rawList -> {
                List<BasicDBObject> result = new ArrayList<>();
                for (Object item : rawList) {
                    switch (item) {
                        case BasicDBObject bdo -> result.add(bdo);
                        case Map map -> result.add(new BasicDBObject(map));
                        case null, default -> log.warn("Unexpected item type in list: {}. Skipping.",
                                item != null ? item.getClass().getName() : "null");
                    }
                }
                yield result;
            }
            default -> {
                log.warn("Expected List but got: {}. Returning empty list.",
                        obj.getClass().getName());
                yield new ArrayList<>();
            }
        };
    }

    private BasicDBObject ensurePayload(Source source) {
        Object payloadObj = source.getPayload();

        return switch (payloadObj) {
            case null -> {
                BasicDBObject payload = new BasicDBObject();
                source.setPayload(payload);
                yield payload;
            }
            case BasicDBObject bdo -> bdo;
            case Map map -> new BasicDBObject(map);
            default -> {
                log.warn("Unexpected payload type: {}. Attempting to parse as JSON.", payloadObj.getClass().getName());
                yield BasicDBObject.parse(payloadObj.toString());
            }
        };
    }

    private List<BasicDBObject> ensureContacts(BasicDBObject payload) {
        Object contactsObj = payload.computeIfAbsent(CONTACTS, k -> new ArrayList<BasicDBObject>());
        List<BasicDBObject> contacts = toBasicDBObjectList(contactsObj);
        payload.put(CONTACTS, contacts);
        return contacts;
    }

    private BasicDBObject ensureContact(List<BasicDBObject> contacts) {
        if (contacts.isEmpty()) {
            BasicDBObject contact = new BasicDBObject();
            contact.put(FIELD_PURPOSE, EMPTY_STRING);
            contact.put(FIELD_PURPOSE_RULE, new ArrayList<>());
            contact.put(CONTACT_DETAILS, new ArrayList<>());
            contacts.add(contact);
            return contact;
        }
        return contacts.getFirst();
    }

    private List<BasicDBObject> ensureContactDetails(BasicDBObject contact) {
        Object detailsObj = contact.computeIfAbsent(CONTACT_DETAILS, k -> new ArrayList<BasicDBObject>());
        List<BasicDBObject> details = toBasicDBObjectList(detailsObj);
        contact.put(CONTACT_DETAILS, details);
        return details;
    }

    private BasicDBObject ensureAutomatedServicesContact(List<BasicDBObject> contactDetails) {
        BasicDBObject automatedServicesContact = findContactDetailByType(contactDetails, CONTACT_AUTOMATED_SERVICES);
        if (automatedServicesContact == null) {
            incrementAllPriorities(contactDetails);
            automatedServicesContact = createAutomatedServicesContact(1);
            contactDetails.add(automatedServicesContact);
        }
        return automatedServicesContact;
    }

    private void incrementAllPriorities(List<BasicDBObject> items) {
        for (BasicDBObject item : items) {
            Object priorityObj = item.get(PRIORITY);
            if (priorityObj != null) {
                int currentPriority = toInt(priorityObj);
                item.put(PRIORITY, currentPriority + 1);
            }
        }
    }

    private BasicDBObject findContactDetailByType(List<BasicDBObject> contactDetails, String type) {
        return contactDetails.stream()
                .filter(cd -> hasType(cd, type))
                .findFirst()
                .orElse(null);
    }

    private boolean hasType(BasicDBObject cd, String type) {
        return type.equals(cd.get(TYPE));
    }

    private int toInt(Object priority) {
        if (priority instanceof Integer i) {
            return i;
        }
        return Integer.parseInt(priority.toString());
    }

    private BasicDBObject createAutomatedServicesContact(int priority) {
        BasicDBObject contact = new BasicDBObject();
        contact.put(FOLLOW_UP_ALLOWED, EMPTY_STRING);
        contact.put(TYPE, CONTACT_AUTOMATED_SERVICES);
        contact.put(PRIORITY, priority);
        contact.put(FIELD_VERSION, EMPTY_STRING);
        contact.put(TURN_AROUND_TIME, EMPTY_STRING);
        contact.put(SUR_CHARGE_AMOUNT, EMPTY_STRING);
        contact.put(NAME, EMPTY_STRING);
        contact.put(SUR_CHARGE_PAYMENT, EMPTY_STRING);
        contact.put(TURN_AROUND_TIME_UNIT, TIME_UNIT_DAYS);
        contact.put(SUR_CHARGE_CURRENCY, EMPTY_STRING);
        contact.put(COMMUNICATION, new ArrayList<>());
        contact.put(FROM_YEAR, EMPTY_STRING);
        contact.put(TO_YEAR, EMPTY_STRING);
        return contact;
    }

    private boolean updateParchmentExchangeCommunication(BasicDBObject contactDetail, ParchmentRecord parchmentRecord, Vendors vendor) {
        List<BasicDBObject> communications = ensureCommunications(contactDetail);
        BasicDBObject parchmentComm = findParchmentCommunication(communications);

        if (parchmentComm == null) {
            incrementAllPriorities(communications);
            parchmentComm = createParchmentExchangeCommunication(parchmentRecord, vendor, 1);
            communications.add(parchmentComm);
            return true;
        }
        return false;
    }

    private List<BasicDBObject> ensureCommunications(BasicDBObject contactDetail) {
        Object commsObj = contactDetail.computeIfAbsent(COMMUNICATION, k -> new ArrayList<BasicDBObject>());
        List<BasicDBObject> communications = toBasicDBObjectList(commsObj);
        contactDetail.put(COMMUNICATION, communications);
        return communications;
    }

    private BasicDBObject findParchmentCommunication(List<BasicDBObject> communications) {
        return communications.stream()
                .filter(this::isParchmentCommunication)
                .findFirst()
                .orElse(null);
    }

    private boolean isParchmentCommunication(BasicDBObject comm) {
        return PARCHMENT_EXCHANGE.equals(comm.get(NAME));
    }

    private BasicDBObject createParchmentExchangeCommunication(ParchmentRecord parchmentRecord, Vendors vendor, int priority) {
        String providerName = Optional.ofNullable(parchmentRecord.getServiceProvider())
                .filter(sp -> !sp.isEmpty())
                .orElse(PARCHMENT_EXCHANGE);

        BasicDBObject communication = new BasicDBObject();
        communication.put(NAME, providerName);
        communication.put(COMMUNICATION_INFO, createCommunicationInfoList(parchmentRecord, vendor));
        communication.put(PROVIDER_ID, String.valueOf(vendor.getProviderId()));
        communication.put(PRIORITY, priority);

        return communication;
    }

    private List<BasicDBObject> createCommunicationInfoList(ParchmentRecord parchmentRecord, Vendors vendor) {
        List<BasicDBObject> infoList = new ArrayList<>();

        infoList.add(createCommunicationInfo(COMPANY_NAMES, parchmentRecord.getInstitutionName()));
        infoList.add(createCommunicationInfo(CODES, parchmentRecord.getCode()));
        infoList.add(createCommunicationInfo(BRANCH, EMPTY_STRING));
        infoList.add(createCommunicationInfo(URI, vendor.getWebsite()));
        infoList.add(createCommunicationInfo(FIELD_SOURCE_TYPE, SOURCE_TYPE_EDUCATION));
        infoList.add(createCommunicationInfo(SURCHARGE_AMOUNT, orEmpty(parchmentRecord.getSurchargeAmount())));
        infoList.add(createCommunicationInfo(SURCHARGE_CURRENCY,
                COUNTRY_USA.equalsIgnoreCase(parchmentRecord.getCountry()) ? CURRENCY_USD : EMPTY_STRING));
        infoList.add(createCommunicationInfo(PAYMENT_METHOD, orEmpty(parchmentRecord.getPaymentMethod())));
        infoList.add(createCommunicationInfo(FOLLOW_UP_ALLOWED, orEmpty(parchmentRecord.getFollowUpAllowed())));
        infoList.add(createCommunicationInfo(FOLLOW_UP_ALLOWED_AFTER, EMPTY_STRING));
        infoList.add(createCommunicationInfo(FOLLOW_UP_ALLOWED_AFTER_UNITS, TIME_UNIT_DAYS));
        infoList.add(createCommunicationInfo(TURN_AROUND_TIME, orEmpty(parchmentRecord.getTurnaroundTime())));
        infoList.add(createCommunicationInfo(TURN_AROUND_TIME_UNIT, TIME_UNIT_DAYS));
        infoList.add(createCommunicationInfo(FROM_YEAR, EMPTY_STRING));
        infoList.add(createCommunicationInfo(TO_YEAR, EMPTY_STRING));

        return infoList;
    }

    private String orEmpty(String value) {
        return value != null ? value : EMPTY_STRING;
    }

    private BasicDBObject createCommunicationInfo(String type, String value) {
        BasicDBObject info = new BasicDBObject();
        info.put(TYPE, type);
        info.put(VALUE, orEmpty(value));
        return info;
    }

}
