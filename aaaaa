PROCEDURE inject
(
    psTemplate IN OUT NCLOB,
    psFieldName IN NVARCHAR2,
    psFieldValue IN NVARCHAR2
)
IS
BEGIN
  html.changeUTF8(psTemplate, psFieldName, TRIM(escapeXMLSymbols(psFieldValue)));
END;

