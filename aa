package com.hireright.sourceintelligence.config;

import jakarta.annotation.PostConstruct;
import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.springframework.context.annotation.Configuration;
import org.springframework.data.domain.Sort;
import org.springframework.data.mongodb.core.MongoTemplate;
import org.springframework.data.mongodb.core.index.Index;
import org.springframework.data.mongodb.core.index.IndexOperations;

@Slf4j
@Configuration
@RequiredArgsConstructor
public class MongoIndexConfig {

    private final MongoTemplate mongoTemplate;

    @PostConstruct
    public void initIndexes() {
        createParchmentSourceIndexes();
    }

    private void createParchmentSourceIndexes() {
        try {
            IndexOperations indexOps = mongoTemplate.indexOps("education_source_parchment_test");

            // Index 1: Compound index for location + name matching (MOST IMPORTANT)
            Index locationNameIndex = new Index()
                    .on("state", Sort.Direction.ASC)
                    .on("city", Sort.Direction.ASC)
                    .on("country", Sort.Direction.ASC)
                    .on("organizationName", Sort.Direction.ASC)
                    .named("idx_location_name")
                    .background();
            
            indexOps.ensureIndex(locationNameIndex);
            log.info("✓ Created/verified index: idx_location_name");

            // Index 2: State-only index for initial filtering
            Index stateIndex = new Index()
                    .on("state", Sort.Direction.ASC)
                    .named("idx_state")
                    .background();
            
            indexOps.ensureIndex(stateIndex);
            log.info("✓ Created/verified index: idx_state");

            // Index 3: State + alias index for alias lookups
            Index stateAliasIndex = new Index()
                    .on("state", Sort.Direction.ASC)
                    .on("organizationAlias.name", Sort.Direction.ASC)
                    .named("idx_state_alias")
                    .background();
            
            indexOps.ensureIndex(stateAliasIndex);
            log.info("✓ Created/verified index: idx_state_alias");

            // Index 4: Location-only compound index
            Index locationIndex = new Index()
                    .on("state", Sort.Direction.ASC)
                    .on("city", Sort.Direction.ASC)
                    .on("country", Sort.Direction.ASC)
                    .named("idx_location")
                    .background();
            
            indexOps.ensureIndex(locationIndex);
            log.info("✓ Created/verified index: idx_location");

            log.info("All Parchment source indexes created/verified successfully");

        } catch (Exception e) {
            log.error("Failed to create MongoDB indexes for Parchment sources", e);
        }
    }
}

