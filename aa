jacoco {
    toolVersion="0.8.11"
    reportsDirectory = layout.buildDirectory.dir('customJacocoReportDir')
}

jacocoTestReport {
    executionData tasks.withType(Test)
    dependsOn test // tests are required to run before generating the report
    classDirectories.from = files(sourceSets.main.output.classesDirs)
    sourceDirectories.from = files(sourceSets.main.java.srcDirs)

    reports {
        xml.required = true
        xml.destination file("build/reports/jacoco.xml")
        csv.required = false
        html.required = true
        html.outputLocation = layout.buildDirectory.dir('jacocoHtml')

    }

    afterEvaluate {
        classDirectories.setFrom(files(classDirectories.files.collect {
            fileTree(dir: it, exclude: [
                    "**/constants/**",
                    "**/ApiConstants",
                    "**/exception/**",
                    "**/dto/**",
                    "**/entity/**",
                    "**/enums/**",
                    "**/repository/**",
                    "**/SourceIntelligenceServiceApplication*",
                    "**/DefaultApprovalWorkflowService*",
                    "**/ApprovalWorkflowService*",
                    "**/ApprovalWorkflowMapper*"
            ])
        }))
    }
}

jacocoTestCoverageVerification {
    violationRules {
        rule {
            element = 'CLASS'
            limit {
                counter = 'LINE'
                value = 'COVEREDRATIO'
                minimum = 0.1
            }
            excludes = [
                    'com.hireright.sourceintelligence.exception.**',
                    'com.hireright.sourceintelligence.domain.entity.**',
                    'com.hireright.sourceintelligence.domain.enums.**',
                    'com.hireright.sourceintelligence.domain.repository.**',
                    'com.hireright.sourceintelligence.SourceIntelligenceServiceApplication*',
                    'com.hireright.sourceintelligence.api.dto.**',
                    'com.hireright.sourceintelligence.api.ApiConstants*',
                    'com.hireright.sourceintelligence.constants.**',
                    'com.hireright.sourceintelligence.config.DatabaseConfiguration',
                    'com.hireright.verificationcenterservice.messaging.publisher.**',
            ]
        }
    }
}
