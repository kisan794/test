PROCEDURE update_commonDetails(psTmpl IN OUT NVARCHAR2, nestedObj IN JSON_OBJECT_T, psPriority OUT VARCHAR2, psEquifaxHighSchoolDateRange IN VARCHAR2 := '')
IS
  turnAroundTime VARCHAR2(100);
  turnAroundTimeUnit VARCHAR2(100);
  paymentMethod VARCHAR2(100);
  surchargeAmount VARCHAR2(100);
  surchargeCurrency VARCHAR2(100);
  followUpAllowedAfter VARCHAR2(100);
  followUpAllowedAfterUnit VARCHAR2(100);
  isFollowUpAllowed VARCHAR2(100);
  recordDateFromYear VARCHAR2(10) := '';
  recordDateToYear   VARCHAR2(10) := '';
BEGIN
    surchargeAmount := nestedObj.get_string('surchargeAmount');
    inject(psTmpl, '%SURCHARGE_AMOUNT%', surchargeAmount);

    surchargeCurrency := nestedObj.get_string('surchargeCurrency');
    inject(psTmpl, '%SURCHARGE_CURRENCY%', surchargeCurrency);
        
    turnAroundTime := nestedObj.get_string('turnAroundTime');
    inject(psTmpl, '%TURNAROUND_TIME%', turnAroundTime);

    turnAroundTimeUnit := nestedObj.get_string('turnAroundTimeUnit');
    inject(psTmpl, '%TURNAROUND_TIME_UNIT%', turnAroundTimeUnit);

    paymentMethod := nestedObj.get_string('paymentMethod');
	inject(psTmpl, '%PAYMENT_METHOD%', paymentMethod);

    followUpAllowedAfter := nestedObj.get_string('followUpAllowedAfter');
    inject(psTmpl, '%FOLLOW_UP_REQUIRED_AFTER%', followUpAllowedAfter);

    followUpAllowedAfterUnit := nestedObj.get_string('followUpAllowedAfterUnit');
    inject(psTmpl, '%FOLLOW_UP_REQUIRED_AFTER_TIME_UNIT%', followUpAllowedAfterUnit);

    isFollowUpAllowed := nestedObj.get_string('isFollowUpAllowed');
    inject(psTmpl, '%FOLLOW_UP_REQUIRED%', isFollowUpAllowed);
	
	IF NVL(psEquifaxHighSchoolDateRange, ' ') != ' '
	THEN
		BEGIN
			recordDateFromYear := REGEXP_SUBSTR(psEquifaxHighSchoolDateRange, '[^,]+', 1, 1);
			recordDateToYear   := REGEXP_SUBSTR(psEquifaxHighSchoolDateRange, '[^,]+', 1, 2);
		END;
	END IF;
	
    inject(psTmpl, '%RECORD_DATE_FROM_YEAR%', recordDateFromYear);
    inject(psTmpl, '%RECORD_DATE_TO_YEAR%', recordDateToYear);
	
	psPriority := nestedObj.get_string('priority');
        
END update_commonDetails; 


